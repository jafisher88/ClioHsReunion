---
interface Props {
  icon?: string;
  title: string;
}
const { icon, title } = Astro.props;
---

<div class="rounded-2xl border-2 border-cream-300 bg-white/70 p-6 shadow-sm transition-transform hover:-translate-y-0.5 hover:border-brand-300">
  {icon && <div class="text-3xl">{icon}</div>}
  <h3 class="mt-3 font-heading text-xl uppercase tracking-wider text-brand-800">{title}</h3>
  <div class="mt-2 text-brand-700 leading-relaxed">
    <slot />
  </div>
</div>
