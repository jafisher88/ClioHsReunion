---
interface Props {
  icon?: string;
  title: string;
  num?: string;
}
const { icon, title, num } = Astro.props;
---

<article class="catalog-entry">
  <header class="catalog-entry-num">
    <span>{num ?? '◦'}</span>
    <span>{title}</span>
  </header>
  {icon && <div class="catalog-entry-icon" aria-hidden="true">{icon}</div>}
  <div class="catalog-entry-body">
    <slot />
  </div>
</article>

<style>
  .catalog-entry-icon {
    font-size: 2rem;
    line-height: 1;
    margin-top: 0.2rem;
    color: var(--color-brand-500);
  }
  .catalog-entry-body {
    font-family: var(--font-body);
    color: var(--color-brand-800);
    line-height: 1.5;
    font-size: 0.95rem;
  }
  .catalog-entry-body :global(p) { margin: 0; }
  .catalog-entry-body :global(p + p) { margin-top: 0.5rem; }
</style>
