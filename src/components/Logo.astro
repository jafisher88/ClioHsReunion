---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  variant?: 'light' | 'dark';
}
const { size = 'md', variant = 'light' } = Astro.props;
const sizes = { sm: 'text-base', md: 'text-xl', lg: 'text-3xl' } as const;
const yearSizes = { sm: 'text-xs', md: 'text-sm', lg: 'text-base' } as const;
const primary = variant === 'dark' ? 'text-cream-100' : 'text-brand-700';
const secondary = variant === 'dark' ? 'text-accent-300' : 'text-accent-600';
---

<span class={`inline-flex items-baseline gap-2 leading-none ${sizes[size]} font-heading uppercase tracking-wider`}>
  <span class={primary}>Clio HS</span>
  <span class={`${secondary} ${yearSizes[size]} font-display italic normal-case tracking-normal`}>· Class of '06</span>
</span>
