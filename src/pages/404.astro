---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not Found">
  <div class="mx-auto max-w-xl py-16 text-center animate-fade-in">
    <p class="font-script text-3xl text-accent-600">Lost in the hallway</p>
    <h1 class="mt-2 font-heading text-6xl font-bold uppercase tracking-wider text-brand-800">404</h1>
    <p class="mt-4 text-brand-700">
      We couldn't find that page. Maybe try the front office?
    </p>
    <a
      href="/"
      class="mt-8 inline-flex rounded-full bg-brand-500 px-6 py-3 text-base font-semibold text-cream-50 hover:bg-brand-600"
    >
      Back to home →
    </a>
  </div>
</Layout>
