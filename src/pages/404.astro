---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not Found">
  <div class="reveal mx-auto max-w-xl py-12 text-center sm:py-20">
    <span class="section-kicker mx-auto">Lost in the hallway</span>
    <h1 class="mt-3 font-heading text-7xl font-bold uppercase tracking-[0.05em] text-brand-900 sm:text-8xl">
      <span class="bg-gradient-to-br from-brand-500 to-brand-700 bg-clip-text text-transparent">404</span>
    </h1>
    <p class="mt-5 leading-relaxed text-brand-700">
      We couldn't find that page. Maybe try the front office?
    </p>
    <a
      href="/"
      class="group/cta mt-8 inline-flex items-center gap-2 rounded-full bg-brand-500 px-6 py-3 text-base font-semibold text-cream-50 shadow-[0_2px_0_rgba(13,11,10,0.04),0_12px_24px_-8px_rgba(242,105,1,0.5)] transition-all duration-200 hover:bg-brand-600 hover:-translate-y-0.5"
    >
      Back to home
      <span class="transition-transform duration-200 group-hover/cta:translate-x-0.5" aria-hidden="true">→</span>
    </a>
  </div>
</Layout>
