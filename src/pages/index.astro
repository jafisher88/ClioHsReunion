---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import VolunteerForm from '../components/VolunteerForm.tsx';
---

<Layout title="Home">
  {/* ---------- HERO ---------- */}
  <section class="reveal animate-fade-in pt-2">
    <div class="group/hero relative overflow-hidden rounded-3xl bg-gradient-to-br from-brand-600 via-brand-800 to-brand-900 px-6 py-16 text-center shadow-2xl sm:py-24">
      {/* Layered radial highlights for depth */}
      <div
        class="pointer-events-none absolute inset-0 opacity-10"
        style="background-image: radial-gradient(circle at 18% 22%, var(--color-brand-400) 0, transparent 42%), radial-gradient(circle at 82% 78%, var(--color-brand-500) 0, transparent 42%);"
        aria-hidden="true"
      ></div>
      {/* Subtle inner vignette */}
      <div
        class="pointer-events-none absolute inset-0 opacity-60"
        style="background: radial-gradient(ellipse at center, transparent 50%, rgba(13, 11, 10, 0.35) 100%);"
        aria-hidden="true"
      ></div>

      {/* Small mono mark — "20 years since 2006" */}
      <div class="relative mx-auto mb-8 inline-flex items-center gap-2 rounded-full border border-cream-200/30 bg-cream-50/5 px-4 py-1.5 backdrop-blur-sm">
        <span class="h-1.5 w-1.5 rounded-full bg-accent-400" aria-hidden="true"></span>
        <span class="font-heading text-[0.65rem] font-semibold uppercase tracking-[0.28em] text-cream-200/85">
          20 Years &nbsp;·&nbsp; Anno MMXXVI
        </span>
      </div>

      <img
        src="/clio-mustang.png"
        alt="Clio Mustangs"
        width="180"
        height="121"
        class="relative mx-auto h-auto w-32 drop-shadow-2xl transition-transform duration-500 ease-out group-hover/hero:scale-105 sm:w-44"
      />
      <p class="relative mt-6 font-script text-2xl text-accent-300 sm:text-3xl">Save the date</p>
      <h1 class="relative mt-3 font-heading text-4xl font-bold uppercase tracking-[0.06em] text-cream-50 sm:text-6xl">
        Clio High School Class of 2006
      </h1>
      <p class="relative mt-3 font-display text-xl italic text-accent-200 sm:text-2xl">20-Year Reunion</p>

      {/* Hairline divider */}
      <div class="relative mx-auto mt-7 h-px w-16 bg-cream-200/30" aria-hidden="true"></div>

      <p class="relative mx-auto mt-7 max-w-2xl text-base leading-relaxed text-cream-200/90 sm:text-lg">
        It's been 20 years since we graduated. Let's get back together —
        old friends, old stories, a few new gray hairs.
      </p>

      <div class="relative mt-10 flex flex-wrap justify-center gap-3 sm:gap-4">
        <a
          href="/rsvp"
          class="group/cta inline-flex items-center gap-2 rounded-full bg-accent-500 px-8 py-3.5 text-base font-semibold text-brand-900 shadow-[0_2px_0_rgba(13,11,10,0.06),0_12px_24px_-8px_rgba(220,185,70,0.5)] transition-all duration-200 hover:bg-accent-400 hover:-translate-y-0.5 hover:shadow-[0_2px_0_rgba(13,11,10,0.06),0_16px_28px_-10px_rgba(220,185,70,0.65)] focus-visible:bg-accent-400"
        >
          RSVP now
          <span class="transition-transform duration-200 group-hover/cta:translate-x-0.5" aria-hidden="true">→</span>
        </a>
        <a
          href="/event"
          class="inline-flex items-center gap-2 rounded-full border-2 border-cream-200/40 px-8 py-3.5 text-base font-medium text-cream-100 transition-all duration-200 hover:border-cream-200 hover:bg-cream-50/10 hover:-translate-y-0.5"
        >
          Event details
        </a>
      </div>
    </div>
  </section>

  {/* ---------- WHEN / WHERE / WHAT ---------- */}
  <section class="reveal mt-16 sm:mt-24">
    <header class="mb-8 flex flex-col items-start gap-2 sm:mb-10">
      <span class="section-kicker">The particulars</span>
      <h2 class="font-heading text-2xl font-semibold uppercase tracking-[0.05em] text-brand-900 sm:text-3xl">
        Save the date — here's what we know.
      </h2>
    </header>

    <div class="grid gap-4 sm:grid-cols-3 sm:gap-5">
      <Card icon="📅" title="When">
        <p>November 2026 — the exact date is being voted on in the Facebook group.</p>
      </Card>
      <a
        href="https://www.google.com/maps/search/?api=1&query=Round+Em+Up+Ranch+Clio+MI"
        target="_blank"
        rel="noopener noreferrer"
        class="block no-underline rounded-2xl focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-500"
      >
        <Card icon="📍" title="Where">
          <p>
            <span class="font-semibold text-brand-900">Round Em Up Ranch</span> in Clio, Michigan.
          </p>
          <p class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600">
            Open in Google Maps
            <span aria-hidden="true">↗</span>
          </p>
        </Card>
      </a>
      <Card icon="🎉" title="What">
        <p>One night of catching up — drinks, food, music, and twenty years of stories.</p>
      </Card>
    </div>
  </section>

  {/* ---------- HELP COVER COSTS ---------- */}
  <section class="reveal mt-16 sm:mt-24">
    <div class="relative overflow-hidden rounded-3xl border border-cream-300 bg-white/80 shadow-soft">
      {/* Subtle decorative accent stripe */}
      <div class="absolute left-0 top-0 h-full w-1 bg-gradient-to-b from-brand-400 via-brand-500 to-accent-500" aria-hidden="true"></div>

      <div class="grid gap-8 p-8 sm:p-12 lg:grid-cols-5 lg:items-center">
        <div class="lg:col-span-3">
          <span class="section-kicker">Pitch in</span>
          <h2 class="mt-2 font-heading text-3xl font-semibold uppercase tracking-[0.05em] text-brand-900 sm:text-4xl">
            Help cover costs
          </h2>
          <p class="mt-4 max-w-xl text-brand-700 leading-relaxed">
            We're still nailing down the final per-head cost, so for now this is open as
            a donation to help cover the costs.
            <span class="font-semibold text-brand-900">Any amount helps.</span>
            Once costs are firm we'll share an official number.
          </p>
          <p class="mt-3 inline-flex items-center gap-2 rounded-full bg-accent-50 px-3 py-1 text-xs font-medium text-accent-700">
            <span aria-hidden="true">✿</span>
            Please send as <span class="font-semibold">friends &amp; family</span>
          </p>

          <div class="mt-6 flex flex-wrap items-center gap-3">
            <a
              href="https://venmo.com/u/Jafisher88"
              target="_blank"
              rel="noopener noreferrer"
              class="group/venmo inline-flex items-center gap-2 rounded-full bg-brand-500 px-6 py-3 text-base font-semibold text-cream-50 shadow-[0_2px_0_rgba(13,11,10,0.04),0_12px_24px_-8px_rgba(242,105,1,0.5)] transition-all duration-200 hover:bg-brand-600 hover:-translate-y-0.5"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.5 4.5c.6 1 .9 2 .9 3.4 0 4.3-3.7 9.9-6.7 13.8H7L4.5 4.5h5.4l1.3 10.5c1.2-2 2.7-5.1 2.7-7.3 0-1.2-.2-2-.5-2.7l5.1-.5z" />
              </svg>
              Send via Venmo
              <span class="text-cream-50/70 transition-transform duration-200 group-hover/venmo:translate-x-0.5" aria-hidden="true">→</span>
            </a>
            <span class="text-sm text-cream-700">
              or pay <span class="rounded bg-cream-100 px-1.5 py-0.5 font-mono text-[0.85rem] font-semibold text-brand-900">@Jafisher88</span> in the app
            </span>
          </div>
        </div>

        <div class="lg:col-span-2 flex justify-center">
          <figure class="flex flex-col items-center">
            <div class="relative rounded-2xl bg-white p-4 ring-1 ring-cream-300 shadow-soft">
              {/* Corner ticks for "scan code" feel */}
              <span class="absolute left-2 top-2 h-3 w-3 border-l-2 border-t-2 border-brand-400" aria-hidden="true"></span>
              <span class="absolute right-2 top-2 h-3 w-3 border-r-2 border-t-2 border-brand-400" aria-hidden="true"></span>
              <span class="absolute left-2 bottom-2 h-3 w-3 border-l-2 border-b-2 border-brand-400" aria-hidden="true"></span>
              <span class="absolute right-2 bottom-2 h-3 w-3 border-r-2 border-b-2 border-brand-400" aria-hidden="true"></span>
              <img
                src="/venmo-qr.svg"
                alt="Venmo QR code for @Jafisher88"
                width="180"
                height="180"
                class="block h-40 w-40 sm:h-44 sm:w-44"
              />
            </div>
            <figcaption class="mt-3 text-xs font-medium text-cream-700 text-center">
              Scan with your phone camera to open Venmo
            </figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>

  {/* ---------- SEEKING VOLUNTEERS ---------- */}
  <section class="reveal mt-16 sm:mt-24">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-brand-50/80 via-cream-50 to-accent-50/70 shadow-soft">
      <div class="grid gap-10 p-8 sm:p-12 lg:grid-cols-5">
        <div class="lg:col-span-2">
          <span class="section-kicker">We need a few hands</span>
          <h2 class="mt-2 font-heading text-3xl font-semibold uppercase tracking-[0.05em] text-brand-900 sm:text-4xl">
            Seeking volunteers
          </h2>
          <p class="mt-4 text-brand-700 leading-relaxed">
            A reunion this good doesn't run itself. We're looking for classmates
            who can lend a hand either the <span class="font-semibold text-brand-900">day before</span>
            (setup &amp; decorate) or the <span class="font-semibold text-brand-900">day after</span>
            (cleanup). One day, both — totally up to you.
          </p>
          <ul class="mt-6 space-y-3 text-brand-700">
            <li class="flex gap-3">
              <span class="mt-1.5 inline-flex h-2 w-2 shrink-0 rounded-full bg-brand-500 ring-4 ring-brand-100" aria-hidden="true"></span>
              <span><span class="font-semibold text-brand-900">Day before</span> — set up tables, hang decorations, prep the space.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-1.5 inline-flex h-2 w-2 shrink-0 rounded-full bg-brand-500 ring-4 ring-brand-100" aria-hidden="true"></span>
              <span><span class="font-semibold text-brand-900">Day after</span> — tear-down, trash, pack up decorations.</span>
            </li>
          </ul>
          <p class="mt-6 text-sm italic text-cream-700">
            Already RSVP'd? Volunteering is separate from attending.
          </p>
        </div>

        <div class="lg:col-span-3">
          <div class="rounded-2xl border border-cream-300 bg-white p-6 shadow-soft sm:p-8">
            <VolunteerForm client:load />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ---------- STAY IN THE LOOP ---------- */}
  <section class="reveal mt-16 sm:mt-24">
    <header class="mb-8 flex flex-col items-start gap-2">
      <span class="section-kicker">Stay in touch</span>
      <h2 class="font-heading text-2xl font-semibold uppercase tracking-[0.05em] text-brand-900 sm:text-3xl">
        Three places we keep in the loop.
      </h2>
      <p class="mt-1 max-w-2xl text-brand-700">
        Most chatter happens in the Facebook group — including the date vote.
        The alumni site has class pages and history.
      </p>
    </header>

    <div class="grid gap-4 sm:grid-cols-3">
      <a
        href="https://www.facebook.com/share/g/1G2ZxKc1GP/?mibextid=wwXIfr"
        target="_blank"
        rel="noopener noreferrer"
        class="group/link relative flex items-center justify-between gap-4 rounded-2xl border border-cream-300 bg-white/80 p-5 shadow-soft transition-all duration-200 hover:-translate-y-0.5 hover:shadow-soft-hover hover:border-brand-300"
      >
        <div class="min-w-0">
          <div class="font-heading text-xs font-bold uppercase tracking-[0.18em] text-accent-700">Primary</div>
          <div class="mt-1 font-display italic text-lg text-brand-900">Facebook group</div>
          <div class="text-sm text-cream-700">Live chatter &amp; date vote</div>
        </div>
        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-brand-500 text-cream-50 transition-transform duration-200 group-hover/link:translate-x-0.5" aria-hidden="true">↗</span>
      </a>

      <a
        href="https://cliohighschool.net/class-of-2006.html"
        target="_blank"
        rel="noopener noreferrer"
        class="group/link relative flex items-center justify-between gap-4 rounded-2xl border border-cream-300 bg-white/60 p-5 shadow-soft transition-all duration-200 hover:-translate-y-0.5 hover:shadow-soft-hover hover:border-brand-300"
      >
        <div class="min-w-0">
          <div class="font-heading text-xs font-bold uppercase tracking-[0.18em] text-cream-700">Alumni</div>
          <div class="mt-1 font-display italic text-lg text-brand-900">cliohighschool.net</div>
          <div class="text-sm text-cream-700">Class page &amp; history</div>
        </div>
        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-cream-400 text-brand-700 transition-all duration-200 group-hover/link:bg-brand-500 group-hover/link:text-cream-50 group-hover/link:border-brand-500" aria-hidden="true">↗</span>
      </a>

      <a
        href="/gallery"
        class="group/link relative flex items-center justify-between gap-4 rounded-2xl border border-cream-300 bg-white/60 p-5 shadow-soft transition-all duration-200 hover:-translate-y-0.5 hover:shadow-soft-hover hover:border-brand-300"
      >
        <div class="min-w-0">
          <div class="font-heading text-xs font-bold uppercase tracking-[0.18em] text-cream-700">Throwbacks</div>
          <div class="mt-1 font-display italic text-lg text-brand-900">Video archive</div>
          <div class="text-sm text-cream-700">YouTube playlist on /gallery</div>
        </div>
        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-cream-400 text-brand-700 transition-all duration-200 group-hover/link:bg-brand-500 group-hover/link:text-cream-50 group-hover/link:border-brand-500" aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</Layout>
