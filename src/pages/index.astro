---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
---

<Layout title="Home">
  <section class="animate-fade-in pt-4">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-brand-600 via-brand-800 to-brand-900 px-6 py-16 text-center shadow-2xl sm:py-24">
      <div
        class="absolute inset-0 opacity-10"
        style="background-image: radial-gradient(circle at 20% 20%, var(--color-brand-400) 0, transparent 40%), radial-gradient(circle at 80% 80%, var(--color-brand-500) 0, transparent 40%);"
      ></div>
      <img
        src="/clio-mustang.png"
        alt="Clio Mustangs"
        width="180"
        height="121"
        class="relative mx-auto h-auto w-32 drop-shadow-xl sm:w-44"
      />
      <p class="relative mt-6 font-script text-2xl text-accent-300 sm:text-3xl">Save the date</p>
      <h1 class="relative mt-3 font-heading text-4xl font-bold uppercase tracking-wider text-cream-50 sm:text-6xl">
        Clio High School Class of 2006
      </h1>
      <p class="relative mt-2 font-display text-xl italic text-accent-200 sm:text-2xl">20-Year Reunion</p>
      <p class="relative mx-auto mt-8 max-w-2xl text-base leading-relaxed text-cream-200 sm:text-lg">
        It's been 20 years since we graduated. Let's get back together —
        old friends, old stories, a few new gray hairs.
      </p>
      <div class="relative mt-10 flex flex-wrap justify-center gap-4">
        <a
          href="/rsvp"
          class="group rounded-full bg-accent-500 px-8 py-3.5 text-base font-semibold text-brand-900 shadow-lg shadow-accent-500/30 transition-all hover:bg-accent-400"
        >
          RSVP now <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
        </a>
        <a
          href="/event"
          class="rounded-full border-2 border-cream-200/40 px-8 py-3.5 text-base font-medium text-cream-100 hover:border-cream-200 hover:bg-cream-50/10"
        >
          Event details
        </a>
      </div>
    </div>
  </section>

  <section class="mt-16 grid gap-6 animate-fade-up sm:mt-24 sm:grid-cols-3">
    <Card icon="📅" title="When">
      <p>November 2026 — the exact date is being voted on in the Facebook group.</p>
    </Card>
    <a
      href="https://www.google.com/maps/search/?api=1&query=Round+Em+Up+Ranch+Clio+MI"
      target="_blank"
      rel="noopener noreferrer"
      class="block no-underline focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-500 rounded-2xl"
    >
      <Card icon="📍" title="Where">
        <p>
          <span class="font-semibold text-brand-800">Round Em Up Ranch</span> in Clio, Michigan.
          Hosted by our own classmate Amber, the ranch's owner.
        </p>
        <p class="mt-3 text-sm font-medium text-accent-700">Open in Google Maps →</p>
      </Card>
    </a>
    <Card icon="🎉" title="What">
      <p>One night of catching up — drinks, food, music, and twenty years of stories.</p>
    </Card>
  </section>

  <section class="mt-16 animate-fade-up sm:mt-24">
    <div class="rounded-3xl border-2 border-cream-300 bg-white/70 p-8 shadow-sm sm:p-12">
      <h2 class="font-heading text-3xl uppercase tracking-wider text-brand-800 sm:text-4xl">Stay in the loop</h2>
      <p class="mt-3 max-w-2xl text-brand-700">
        The Class of 2006 Facebook group is where most chatter happens — including the
        ongoing date vote. The official Clio High School alumni site also keeps class
        pages for graduates and class history.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="https://www.facebook.com/share/g/1G2ZxKc1GP/?mibextid=wwXIfr"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-full bg-brand-500 px-6 py-2.5 text-sm font-semibold text-cream-50 hover:bg-brand-600"
        >
          Facebook group →
        </a>
        <a
          href="https://cliohighschool.net/class-of-2006.html"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-full border-2 border-brand-300 bg-white px-6 py-2.5 text-sm font-medium text-brand-700 hover:border-brand-500"
        >
          cliohighschool.net →
        </a>
        <a
          href="/gallery"
          class="rounded-full border-2 border-brand-300 bg-white px-6 py-2.5 text-sm font-medium text-brand-700 hover:border-brand-500"
        >
          Throwback videos →
        </a>
      </div>
    </div>
  </section>
</Layout>
