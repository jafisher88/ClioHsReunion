---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { getAdmin, loginUrlFor } from '../../lib/admin-auth';

const admin = await getAdmin(Astro.request, env);
if (!admin) {
  return Astro.redirect(loginUrlFor(Astro.request));
}
---

<AdminLayout title="Email blast" adminEmail={admin.email}>
  <div style="background: red; color: white; padding: 40px; font-size: 32px; font-weight: bold; text-align: center; border: 4px solid black;">
    TEST CONTENT · BUILD 2026-05-12T21:15Z · IF YOU SEE THIS, THE PAGE RENDERS
  </div>
  <p style="margin-top: 20px; font-family: monospace;">
    Authed as: {admin.email}
  </p>
</AdminLayout>
