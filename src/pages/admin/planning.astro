---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { getAdmin, loginUrlFor } from '../../lib/admin-auth';
import { dbToIso } from '../../lib/admin-dates';

const admin = await getAdmin(Astro.request, env);
if (!admin) {
  return Astro.redirect(loginUrlFor(Astro.request));
}

interface PlanningRow {
  Id: number;
  Sort: number;
  Label: string;
  IsDone: number;
  Notes: string | null;
  UpdatedBy: string | null;
  UpdatedAt: string;
}

const result = await env.DB
  .prepare(`SELECT Id, Sort, Label, IsDone, Notes, UpdatedBy, UpdatedAt FROM PlanningItems ORDER BY Sort ASC, Id ASC`)
  .all<PlanningRow>();
const items = result.results ?? [];

const total = items.length;
const done = items.filter((i) => i.IsDone === 1).length;
const remaining = total - done;
const percent = total === 0 ? 0 : Math.round((done / total) * 100);
---

<AdminLayout title="Planning" adminEmail={admin.email}>
  <header class="mb-10 flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="font-script text-2xl text-accent-600">Behind the scenes</p>
      <h1 class="mt-1 font-heading text-3xl font-bold uppercase tracking-[0.05em] text-brand-900 sm:text-4xl">Event planning</h1>
      <p class="mt-2 max-w-2xl text-sm text-cream-700">
        The reunion checklist. Tick items off as they're locked in and capture <em>how</em>
        they got solved in the notes so the rest of the crew can pick up where you left off.
      </p>
    </div>
  </header>

  <!-- PROGRESS TILES -->
  <section class="mb-10">
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="admin-tile">
        <div class="admin-tile-label">Items</div>
        <div class="admin-tile-value">{total}</div>
        <div class="admin-tile-sub">on the checklist</div>
      </div>
      <div class="admin-tile is-emerald">
        <div class="admin-tile-label">Done</div>
        <div class="admin-tile-value">{done}</div>
        <div class="admin-tile-sub">solved</div>
      </div>
      <div class="admin-tile is-brand">
        <div class="admin-tile-label">Remaining</div>
        <div class="admin-tile-value">{remaining}</div>
        <div class="admin-tile-sub">to nail down</div>
      </div>
      <div class="admin-tile">
        <div class="admin-tile-label">Progress</div>
        <div class="admin-tile-value">{percent}<span class="text-xl">%</span></div>
        <div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-cream-200">
          <div class="h-full bg-brand-500 transition-[width] duration-300" style={`width:${percent}%`}></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CHECKLIST -->
  <section class="mb-12">
    <header class="mb-4 flex flex-wrap items-center justify-between gap-3">
      <div class="flex items-center gap-3">
        <h2 class="font-heading text-lg font-semibold uppercase tracking-[0.08em] text-brand-900 sm:text-xl">Checklist</h2>
        <button
          type="button"
          id="planning-add-btn"
          class="inline-flex h-8 w-8 items-center justify-center rounded-full border-2 border-brand-500 bg-white text-lg font-semibold leading-none text-brand-700 transition-all duration-150 hover:bg-brand-500 hover:text-cream-50 hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-brand-500/25"
          title="Add a checklist item"
          aria-label="Add a checklist item"
        >
          <span aria-hidden="true">+</span>
        </button>
      </div>
      <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-cream-700">click to toggle · type to save</span>
    </header>

    <form id="planning-add-form" class="mb-4 hidden rounded-2xl border border-brand-300 bg-brand-50/50 p-4 sm:p-5">
      <label class="block">
        <span class="block text-sm font-semibold text-brand-900">New checklist item</span>
        <p class="text-xs text-cream-700">Short label — e.g. "Coat check", "Backup heaters", "Permits".</p>
        <input
          type="text"
          name="label"
          required
          maxlength="200"
          autocomplete="off"
          class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 placeholder-cream-500 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
          placeholder="Item label"
        />
      </label>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <button
          type="submit"
          class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-5 py-1.5 text-sm font-semibold text-cream-50 shadow-[0_2px_0_rgba(13,11,10,0.04),0_6px_14px_-6px_rgba(242,105,1,0.5)] transition-all duration-200 hover:bg-brand-600 hover:-translate-y-0.5"
        >
          Add to checklist
        </button>
        <button
          type="button"
          id="planning-add-cancel"
          class="rounded-full border border-cream-400 bg-white px-4 py-1.5 text-sm font-medium text-brand-700 transition-colors hover:border-brand-500 hover:text-brand-900"
        >
          Cancel
        </button>
        <p id="planning-add-message" class="hidden text-sm"></p>
      </div>
    </form>

    {items.length === 0 ? (
      <div class="rounded-2xl border border-dashed border-cream-300 bg-white/40 p-12 text-center">
        <p class="font-script text-2xl text-cream-700">No items yet.</p>
        <p class="mt-2 text-sm text-cream-700">Run the latest D1 migration to seed the default list.</p>
      </div>
    ) : (
      <ul class="space-y-3">
        {items.map((item) => {
          const updatedBy = item.UpdatedBy && item.UpdatedAt
            ? item.UpdatedBy.split('@')[0]
            : '';
          const updatedIso = item.UpdatedBy && item.UpdatedAt ? dbToIso(item.UpdatedAt) : '';
          return (
            <li
              class:list={[
                'planning-row rounded-2xl border bg-white/90 px-4 py-4 shadow-soft transition-colors duration-150 sm:px-5',
                item.IsDone === 1 ? 'border-emerald-300 bg-emerald-50/40' : 'border-cream-300',
              ]}
              data-item-id={item.Id}
            >
              <div class="flex flex-wrap items-start gap-3 sm:flex-nowrap">
                <label class="flex items-center gap-3 pt-0.5">
                  <input
                    type="checkbox"
                    class="done-cb h-5 w-5 cursor-pointer accent-emerald-600"
                    checked={item.IsDone === 1}
                  />
                </label>
                <div class="flex-1 min-w-0">
                  <div class="flex items-start justify-between gap-2">
                    <p
                      class:list={[
                        'label-text flex-1 min-w-0 font-heading text-base font-semibold tracking-[0.01em] sm:text-lg',
                        item.IsDone === 1 ? 'text-brand-700 line-through decoration-emerald-500/60 decoration-2' : 'text-brand-900',
                      ]}
                    >
                      {item.Label}
                    </p>
                    <div class="row-actions flex shrink-0 items-center gap-1">
                      <button
                        type="button"
                        class="edit-btn rounded-full p-1.5 text-cream-700 transition-colors hover:bg-cream-100 hover:text-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500/25"
                        title="Edit label"
                        aria-label="Edit label"
                      >
                        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                          <path d="M14.06 4.94l1 1L5.92 15.08H4.92v-1L14.06 4.94zm2.83-2.83a1 1 0 011.41 0l1.59 1.59a1 1 0 010 1.41L17.06 6.94l-3-3 2.83-2.83z"/>
                        </svg>
                      </button>
                      <button
                        type="button"
                        class="delete-btn rounded-full p-1.5 text-cream-700 transition-colors hover:bg-rose-50 hover:text-rose-700 focus:outline-none focus:ring-2 focus:ring-rose-300/40"
                        title="Delete item"
                        aria-label="Delete item"
                        data-label={item.Label}
                      >
                        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                          <path fill-rule="evenodd" d="M8 4h4a1 1 0 011 1v1h3a1 1 0 110 2h-1l-.5 9.06A2 2 0 0112.5 19h-5A2 2 0 015.5 17.06L5 8H4a1 1 0 110-2h3V5a1 1 0 011-1zm1 2v0h2V6H9zm-2 4a1 1 0 012 0v5a1 1 0 11-2 0v-5zm4 0a1 1 0 112 0v5a1 1 0 11-2 0v-5z" clip-rule="evenodd"/>
                        </svg>
                      </button>
                    </div>
                  </div>
                  <textarea
                    class="notes-input mt-2 block w-full resize-y rounded-lg border-2 border-cream-300 bg-white px-3 py-2 text-sm text-brand-900 transition-colors duration-150 placeholder-cream-500 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
                    rows="2"
                    placeholder="How is this being handled? (vendor, contact, status…)"
                    data-initial={item.Notes ?? ''}
                  >{item.Notes ?? ''}</textarea>
                  <div class="mt-1.5 flex items-center justify-between gap-2 text-xs">
                    <span class="status-label font-mono uppercase tracking-[0.18em] text-cream-700">
                      {updatedBy ? (
                        <>Last updated by {updatedBy} · <time datetime={updatedIso}>{item.UpdatedAt}</time></>
                      ) : null}
                    </span>
                    <span class="save-flag hidden font-mono uppercase tracking-[0.18em]"></span>
                  </div>
                </div>
              </div>
            </li>
          );
        })}
      </ul>
    )}
  </section>
</AdminLayout>

<script is:inline>
  (function () {
    // -------- Add new item --------
    const addBtn = document.getElementById('planning-add-btn');
    const addForm = document.getElementById('planning-add-form');
    const addCancel = document.getElementById('planning-add-cancel');
    const addMessage = document.getElementById('planning-add-message');

    function setAddMessage(text, tone) {
      addMessage.textContent = text;
      addMessage.classList.remove('hidden', 'text-rose-700', 'text-emerald-700', 'text-brand-700');
      addMessage.classList.add(
        tone === 'error' ? 'text-rose-700' :
        tone === 'ok'    ? 'text-emerald-700' :
                           'text-brand-700',
      );
    }
    function openAdd() {
      addForm.classList.remove('hidden');
      addForm.elements.label.value = '';
      addMessage.classList.add('hidden');
      setTimeout(() => addForm.elements.label.focus(), 0);
    }
    function closeAdd() {
      addForm.classList.add('hidden');
      addMessage.classList.add('hidden');
    }
    addBtn?.addEventListener('click', openAdd);
    addCancel?.addEventListener('click', closeAdd);

    addForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const label = String(new FormData(addForm).get('label') ?? '').trim();
      if (!label) { setAddMessage('Label is required.', 'error'); return; }
      setAddMessage('Adding…', 'info');
      try {
        const res = await fetch('/api/admin/planning', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ label }),
        });
        const body = await res.json().catch(() => ({}));
        if (!res.ok) {
          setAddMessage((body && body.error) || `Failed (${res.status})`, 'error');
          return;
        }
        setAddMessage('Added · reloading', 'ok');
        setTimeout(() => location.reload(), 400);
      } catch {
        setAddMessage('Network error.', 'error');
      }
    });

    // -------- Per-row actions --------
    const rows = document.querySelectorAll('.planning-row');

    function flag(row, text, tone) {
      const el = row.querySelector('.save-flag');
      if (!el) return;
      el.textContent = text;
      el.classList.remove('hidden', 'text-brand-700', 'text-emerald-700', 'text-rose-700');
      el.classList.add(
        tone === 'ok'    ? 'text-emerald-700' :
        tone === 'error' ? 'text-rose-700'    :
                           'text-brand-700',
      );
    }
    function clearFlag(row) {
      row.querySelector('.save-flag')?.classList.add('hidden');
    }

    async function patch(id, payload) {
      const res = await fetch('/api/admin/planning', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, ...payload }),
      });
      if (!res.ok) {
        const body = await res.json().catch(() => ({}));
        throw new Error(body && body.error ? body.error : `Failed (${res.status})`);
      }
      return res.json();
    }

    rows.forEach((row) => {
      const id = Number(row.getAttribute('data-item-id'));
      const checkbox = row.querySelector('.done-cb');
      const notes = row.querySelector('.notes-input');

      checkbox?.addEventListener('change', async () => {
        const isDone = checkbox.checked;
        flag(row, 'saving…', 'info');
        try {
          await patch(id, { isDone });
          // Apply visual state immediately without a full reload.
          row.classList.toggle('border-emerald-300', isDone);
          row.classList.toggle('bg-emerald-50/40', isDone);
          row.classList.toggle('border-cream-300', !isDone);
          const label = row.querySelector('p.font-heading');
          if (label) {
            label.classList.toggle('line-through', isDone);
            label.classList.toggle('decoration-emerald-500/60', isDone);
            label.classList.toggle('decoration-2', isDone);
            label.classList.toggle('text-brand-700', isDone);
            label.classList.toggle('text-brand-900', !isDone);
          }
          flag(row, isDone ? 'done ✓' : 'reopened', 'ok');
          setTimeout(() => clearFlag(row), 1400);
        } catch (err) {
          checkbox.checked = !isDone; // revert
          flag(row, err.message || 'save failed', 'error');
        }
      });

      let timer = null;
      notes?.addEventListener('input', () => {
        if (timer) clearTimeout(timer);
        flag(row, 'typing…', 'info');
        timer = setTimeout(async () => {
          const value = notes.value;
          try {
            await patch(id, { notes: value });
            notes.setAttribute('data-initial', value);
            flag(row, 'saved', 'ok');
            setTimeout(() => clearFlag(row), 1200);
          } catch (err) {
            flag(row, err.message || 'save failed', 'error');
          }
        }, 600);
      });

      // -------- Edit label (inline) --------
      const editBtn = row.querySelector('.edit-btn');
      const labelEl = row.querySelector('.label-text');
      editBtn?.addEventListener('click', () => {
        if (!labelEl) return;
        const current = labelEl.textContent.trim();
        const input = document.createElement('input');
        input.type = 'text';
        input.value = current;
        input.maxLength = 200;
        input.className = 'flex-1 min-w-0 rounded-lg border-2 border-brand-300 bg-white px-2 py-1 font-heading text-base font-semibold text-brand-900 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15 sm:text-lg';
        labelEl.replaceWith(input);
        input.focus();
        input.select();

        async function commit() {
          const next = input.value.trim();
          if (!next || next === current) {
            input.replaceWith(labelEl);
            return;
          }
          flag(row, 'saving…', 'info');
          try {
            await patch(id, { label: next });
            labelEl.textContent = next;
            input.replaceWith(labelEl);
            flag(row, 'renamed', 'ok');
            setTimeout(() => clearFlag(row), 1200);
          } catch (err) {
            flag(row, err.message || 'save failed', 'error');
            input.replaceWith(labelEl);
          }
        }
        function cancel() { input.replaceWith(labelEl); }

        input.addEventListener('blur', commit);
        input.addEventListener('keydown', (e) => {
          if (e.key === 'Enter')      { e.preventDefault(); input.blur(); }
          else if (e.key === 'Escape'){ e.preventDefault(); input.removeEventListener('blur', commit); cancel(); }
        });
      });

      // -------- Delete row --------
      const deleteBtn = row.querySelector('.delete-btn');
      deleteBtn?.addEventListener('click', async () => {
        const label = deleteBtn.getAttribute('data-label') || 'this item';
        if (!confirm(`Remove "${label}" from the checklist?`)) return;
        try {
          const res = await fetch(`/api/admin/planning?id=${encodeURIComponent(id)}`, { method: 'DELETE' });
          if (!res.ok) {
            const body = await res.json().catch(() => ({}));
            alert(body && body.error ? body.error : `Failed (${res.status})`);
            return;
          }
          row.style.transition = 'opacity 0.2s ease';
          row.style.opacity = '0';
          setTimeout(() => location.reload(), 250);
        } catch {
          alert('Network error.');
        }
      });
    });
  })();
</script>
