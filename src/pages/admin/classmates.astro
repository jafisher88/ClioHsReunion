---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { getAdmin, loginUrlFor } from '../../lib/admin-auth';

const admin = await getAdmin(Astro.request, env);
if (!admin) {
  return Astro.redirect(loginUrlFor(Astro.request));
}

interface RosterRow {
  Id: number;
  FullName: string;
  MaidenName: string | null;
  PreferredFirstName: string | null;
  Email: string | null;
  Notes: string | null;
  IsDeceased: number;
  BirthYear: number | null;
  PassingYear: number | null;
  Tribute: string | null;
  PhotoUrl: string | null;
  ObituaryUrl: string | null;
  RsvpAttending: 'yes' | 'no' | 'maybe' | null;
  RsvpGuests: number | null;
  RsvpEmail: string | null;
}

// Match RSVPs to classmates on three OR-paths:
//   1. exact case-insensitive full-name match (current name ↔ roster current)
//   2. Classmate.PreferredFirstName + last-of-FullName ↔ RSVP.FullName
//      (handles "Becky Frey" RSVP against "Rebecca Frey" roster + Becky pref)
//   3. RSVP.GraduationName ↔ Classmate's first-name + Classmate.MaidenName
//      (handles "Rebecca Kirby" graduation entry vs "Rebecca Frey" / maiden Kirby)
// One classmate can match multiple RSVPs; ROW_NUMBER picks the latest.
const rosterResult = await env.DB
  .prepare(
    `SELECT c.Id, c.FullName, c.MaidenName, c.PreferredFirstName, c.Email, c.Notes, c.IsDeceased,
            c.BirthYear, c.PassingYear, c.Tribute, c.PhotoUrl, c.ObituaryUrl,
            r.Attending      AS RsvpAttending,
            r.GuestCount     AS RsvpGuests,
            r.Email          AS RsvpEmail
       FROM Classmates c
       LEFT JOIN (
         SELECT FullName, GraduationName, Attending, GuestCount, Email,
                ROW_NUMBER() OVER (PARTITION BY LOWER(TRIM(FullName)) ORDER BY CreatedAt DESC) AS rn
         FROM Rsvps
       ) r
         ON r.rn = 1 AND (
              LOWER(TRIM(r.FullName)) = LOWER(TRIM(c.FullName))
              OR (c.PreferredFirstName IS NOT NULL AND c.PreferredFirstName <> ''
                  AND LOWER(TRIM(r.FullName)) = LOWER(TRIM(c.PreferredFirstName || ' ' || substr(c.FullName, instr(c.FullName, ' ') + 1))))
              OR (c.MaidenName IS NOT NULL AND c.MaidenName <> ''
                  AND r.GraduationName IS NOT NULL AND r.GraduationName <> ''
                  AND LOWER(TRIM(r.GraduationName)) = LOWER(TRIM(substr(c.FullName, 1, instr(c.FullName, ' ') - 1) || ' ' || c.MaidenName)))
            )
   ORDER BY c.FullName COLLATE NOCASE ASC`
  )
  .all<RosterRow>();
const roster = rosterResult.results ?? [];

const total = roster.length;
const rsvped = roster.filter((r) => r.RsvpAttending !== null).length;
const rsvpYes = roster.filter((r) => r.RsvpAttending === 'yes').length;
const rsvpMaybe = roster.filter((r) => r.RsvpAttending === 'maybe').length;
const deceased = roster.filter((r) => r.IsDeceased === 1).length;
const notYet = total - rsvped - deceased;

// Unmatched RSVPs — same three OR-paths inverted.
const unmatchedResult = await env.DB
  .prepare(
    `SELECT DISTINCT r.FullName, r.Email, r.Attending, r.GraduationName
       FROM Rsvps r
       LEFT JOIN Classmates c
         ON LOWER(TRIM(c.FullName)) = LOWER(TRIM(r.FullName))
         OR (c.PreferredFirstName IS NOT NULL AND c.PreferredFirstName <> ''
             AND LOWER(TRIM(r.FullName)) = LOWER(TRIM(c.PreferredFirstName || ' ' || substr(c.FullName, instr(c.FullName, ' ') + 1))))
         OR (c.MaidenName IS NOT NULL AND c.MaidenName <> ''
             AND r.GraduationName IS NOT NULL AND r.GraduationName <> ''
             AND LOWER(TRIM(r.GraduationName)) = LOWER(TRIM(substr(c.FullName, 1, instr(c.FullName, ' ') - 1) || ' ' || c.MaidenName)))
      WHERE c.Id IS NULL
   ORDER BY r.FullName COLLATE NOCASE ASC`
  )
  .all<{ FullName: string; Email: string; Attending: string; GraduationName: string | null }>();
const unmatched = unmatchedResult.results ?? [];
---

<AdminLayout title="Classmates" adminEmail={admin.email}>
  <header class="mb-10 flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="font-script text-2xl text-accent-600">Class of 2006</p>
      <h1 class="mt-1 font-heading text-3xl font-bold uppercase tracking-[0.05em] text-brand-900 sm:text-4xl">Classmates roster</h1>
      <p class="mt-2 max-w-2xl text-sm text-cream-700">
        The canonical list of '06 graduates (from the yearbook). RSVP submissions
        auto-match against this list by full name <em>or</em> by preferred name + last name.
      </p>
    </div>
  </header>

  <!-- STAT TILES -->
  <section class="mb-10">
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-5">
      <div class="admin-tile">
        <div class="admin-tile-label">Total</div>
        <div class="admin-tile-value">{total}</div>
        <div class="admin-tile-sub">on the roster</div>
      </div>
      <div class="admin-tile is-emerald">
        <div class="admin-tile-label">RSVP'd Yes</div>
        <div class="admin-tile-value">{rsvpYes}</div>
        <div class="admin-tile-sub">confirmed</div>
      </div>
      <div class="admin-tile is-brand">
        <div class="admin-tile-label">Maybes</div>
        <div class="admin-tile-value">{rsvpMaybe}</div>
        <div class="admin-tile-sub">tentative</div>
      </div>
      <div class="admin-tile">
        <div class="admin-tile-label">Not yet</div>
        <div class="admin-tile-value">{notYet}</div>
        <div class="admin-tile-sub">no reply</div>
      </div>
      <div class="admin-tile">
        <div class="admin-tile-label">Remembered</div>
        <div class="admin-tile-value">{deceased}</div>
        <div class="admin-tile-sub">in memoriam</div>
      </div>
    </div>
  </section>

  <!-- ROSTER TABLE -->
  <section class="mb-12">
    <header class="mb-4 flex flex-wrap items-center justify-between gap-3">
      <div class="flex items-center gap-3">
        <h2 class="font-heading text-lg font-semibold uppercase tracking-[0.08em] text-brand-900 sm:text-xl">Roster</h2>
        <button
          type="button"
          id="classmate-add-btn"
          class="inline-flex h-8 w-8 items-center justify-center rounded-full border-2 border-brand-500 bg-white text-lg font-semibold leading-none text-brand-700 transition-all duration-150 hover:bg-brand-500 hover:text-cream-50 hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-brand-500/25"
          title="Add a classmate"
          aria-label="Add a classmate"
        >
          <span aria-hidden="true">+</span>
        </button>
      </div>
      <input
        type="text"
        id="roster-filter"
        placeholder="Filter by name…"
        class="rounded-full border-2 border-cream-300 bg-white px-4 py-1.5 text-sm text-brand-900 placeholder-cream-500 transition-colors duration-150 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
      />
    </header>

    {roster.length === 0 ? (
      <div class="rounded-2xl border border-dashed border-cream-300 bg-white/40 p-12 text-center">
        <p class="font-script text-2xl text-cream-700">No classmates yet.</p>
        <p class="mt-2 text-sm text-cream-700">Use the <strong>+</strong> button above to add the first classmate.</p>
      </div>
    ) : (
      <div class="admin-table-wrap">
        <table class="admin-table" id="roster-table">
          <thead>
            <tr>
              <th class="num">#</th>
              <th>Name</th>
              <th>Yearbook name</th>
              <th>RSVP</th>
              <th>Email</th>
              <th>Notes</th>
              <th class="num">Actions</th>
            </tr>
          </thead>
          <tbody>
            {roster.map((r, idx) => {
              const data = JSON.stringify({
                id: r.Id,
                fullName: r.FullName,
                maidenName: r.MaidenName ?? '',
                preferredFirstName: r.PreferredFirstName ?? '',
                email: r.Email ?? '',
                notes: r.Notes ?? '',
                isDeceased: r.IsDeceased === 1,
                birthYear: r.BirthYear ?? '',
                passingYear: r.PassingYear ?? '',
                tribute: r.Tribute ?? '',
                photoUrl: r.PhotoUrl ?? '',
                obituaryUrl: r.ObituaryUrl ?? '',
              });
              const searchHay = `${r.FullName} ${r.MaidenName ?? ''} ${r.PreferredFirstName ?? ''} ${r.Email ?? ''} ${r.RsvpEmail ?? ''}`.toLowerCase();
              const nameParts = r.FullName.trim().split(/\s+/);
              const firstNameOfFull = nameParts[0] ?? '';
              const lastNameOfFull = nameParts[nameParts.length - 1] ?? '';
              const hasMaiden = !!(r.MaidenName && r.MaidenName.trim() &&
                r.MaidenName.trim().toLowerCase() !== lastNameOfFull.toLowerCase());
              const yearbookName = hasMaiden ? `${firstNameOfFull} ${r.MaidenName!.trim()}` : r.FullName;
              return (
                <tr
                  data-classmate-id={r.Id}
                  data-classmate={data}
                  data-search={searchHay}
                >
                  <td class="num mono dim">{String(idx + 1).padStart(3, '0')}</td>
                  <td>
                    <span class="font-semibold">{r.FullName}</span>
                    {r.IsDeceased === 1 && (
                      <span class="ml-2 font-mono text-[0.62rem] uppercase tracking-[0.18em] text-cream-700">remembered</span>
                    )}
                  </td>
                  <td class="dim">{hasMaiden ? <span class="italic text-brand-800">{yearbookName}</span> : yearbookName}</td>
                  <td>
                    {r.IsDeceased === 1 ? (
                      <span class="font-mono text-[0.62rem] uppercase tracking-[0.18em] text-cream-700">in memoriam</span>
                    ) : r.RsvpAttending === 'yes'   ? <span class="pill yes">✓ Yes{r.RsvpGuests && r.RsvpGuests > 1 ? ' +1' : ''}</span>
                    : r.RsvpAttending === 'maybe' ? <span class="pill maybe">? Maybe</span>
                    : r.RsvpAttending === 'no'    ? <span class="pill no">✗ No</span>
                    : <span class="font-mono text-[0.62rem] uppercase tracking-[0.18em] text-cream-700">not yet</span>}
                  </td>
                  <td class="mono dim">
                    {(() => {
                      const displayEmail = r.RsvpEmail ?? r.Email;
                      if (!displayEmail) return '—';
                      return (
                        <a href={`mailto:${displayEmail}`} class="underline decoration-cream-400 underline-offset-2 hover:text-brand-700">
                          {displayEmail}
                          {!r.RsvpEmail && r.Email && (
                            <span class="ml-1 font-mono text-[0.6rem] text-cream-600" title="from roster, not RSVP">·roster</span>
                          )}
                        </a>
                      );
                    })()}
                  </td>
                  <td class="dim max-w-xs whitespace-pre-wrap">{r.Notes ?? '—'}</td>
                  <td class="num">
                    <div class="inline-flex gap-2">
                      <button
                        type="button"
                        class="edit-btn rounded-full border border-cream-400 bg-white px-3 py-1 font-mono text-[0.62rem] font-semibold uppercase tracking-[0.18em] text-brand-700 transition-colors hover:border-brand-500 hover:text-brand-900"
                      >
                        Edit
                      </button>
                      <button
                        type="button"
                        class="merge-btn rounded-full border border-cream-400 bg-white px-3 py-1 font-mono text-[0.62rem] font-semibold uppercase tracking-[0.18em] text-brand-700 transition-colors hover:border-brand-500 hover:text-brand-900"
                      >
                        Merge
                      </button>
                      <button
                        type="button"
                        class="delete-btn rounded-full border border-rose-300 bg-white px-3 py-1 font-mono text-[0.62rem] font-semibold uppercase tracking-[0.18em] text-rose-700 transition-colors hover:border-rose-500 hover:bg-rose-50"
                        data-name={r.FullName}
                      >
                        Delete
                      </button>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )}
  </section>

  <!-- UNMATCHED RSVPS -->
  <!-- ADD/EDIT MODAL -->
  <div
    id="classmate-modal"
    class="hidden fixed inset-0 items-center justify-center p-4"
    style="z-index: 200;"
    role="dialog"
    aria-modal="true"
    aria-labelledby="classmate-modal-title"
  >
    <div id="classmate-modal-backdrop" class="absolute inset-0 bg-brand-900/55"></div>
    <div class="relative flex max-h-[88vh] w-full max-w-2xl flex-col overflow-hidden rounded-2xl border border-cream-300 bg-cream-50 shadow-2xl">
      <header class="border-b border-cream-300 px-6 py-4">
        <p id="classmate-modal-kicker" class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.22em] text-brand-700">Roster</p>
        <h2 id="classmate-modal-title" class="mt-1 font-heading text-xl font-semibold text-brand-900">Add classmate</h2>
      </header>
      <form id="classmate-modal-form" class="flex-1 overflow-y-auto px-6 py-5">
        <input type="hidden" name="id" value="" />
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          <label class="block sm:col-span-1">
            <span class="block text-sm font-semibold text-brand-900">Full name <span class="text-brand-500">*</span></span>
            <p class="text-xs text-cream-700">As it appears in the yearbook.</p>
            <input
              type="text"
              name="fullName"
              required
              class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 placeholder-cream-500 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
            />
          </label>

          <label class="block sm:col-span-1">
            <span class="block text-sm font-semibold text-brand-900">Preferred first name <span class="font-normal text-cream-700">(optional)</span></span>
            <p class="text-xs text-cream-700">What they go by. e.g. "Becky" for Rebecca.</p>
            <input
              type="text"
              name="preferredFirstName"
              class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 placeholder-cream-500 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
            />
          </label>

          <label class="block sm:col-span-1">
            <span class="block text-sm font-semibold text-brand-900">Maiden name <span class="font-normal text-cream-700">(last name only, optional)</span></span>
            <p class="text-xs text-cream-700">Just the surname they had in the yearbook — e.g. "Kirby" for Rebecca Frey, not "Rebecca Kirby".</p>
            <input
              type="text"
              name="maidenName"
              class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 placeholder-cream-500 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
            />
          </label>

          <label class="block sm:col-span-1">
            <span class="block text-sm font-semibold text-brand-900">Email <span class="font-normal text-cream-700">(optional)</span></span>
            <p class="text-xs text-cream-700">Used as fallback contact if they haven't RSVP'd yet.</p>
            <input
              type="email"
              name="email"
              autocomplete="off"
              class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 placeholder-cream-500 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
            />
          </label>

          <label class="block sm:col-span-2">
            <span class="block text-sm font-semibold text-brand-900">Notes <span class="font-normal text-cream-700">(optional — lives in CA, lost contact, etc.)</span></span>
            <textarea
              name="notes"
              rows="2"
              class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 placeholder-cream-500 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
            ></textarea>
          </label>

          <label class="flex items-center gap-2 sm:col-span-2">
            <input id="cm-deceased-cb" type="checkbox" name="isDeceased" class="h-4 w-4 accent-brand-500" />
            <span class="text-sm text-brand-900">Mark as deceased — show memorial details below.</span>
          </label>

          <div id="cm-memorial-section" class="hidden sm:col-span-2 mt-1 rounded-2xl border border-cream-300 bg-cream-100/60 p-4 space-y-4">
            <header class="flex items-baseline justify-between gap-2">
              <p class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.22em] text-brand-700">Memorial details</p>
              <p class="text-xs italic text-cream-700">Shown on the public <a href="/memoriam" class="underline hover:text-brand-700" target="_blank" rel="noopener">In Memoriam</a> page.</p>
            </header>

            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <label class="block">
                <span class="block text-sm font-semibold text-brand-900">Birth year <span class="font-normal text-cream-700">(optional)</span></span>
                <input
                  type="number"
                  name="birthYear"
                  min="1900"
                  max="2100"
                  class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 tabular-nums transition-colors duration-150 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
                />
              </label>

              <label class="block">
                <span class="block text-sm font-semibold text-brand-900">Passing year <span class="font-normal text-cream-700">(optional)</span></span>
                <input
                  type="number"
                  name="passingYear"
                  min="1900"
                  max="2100"
                  class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 tabular-nums transition-colors duration-150 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
                />
              </label>

              <label class="block sm:col-span-2">
                <span class="block text-sm font-semibold text-brand-900">Obituary URL <span class="font-normal text-cream-700">(optional)</span></span>
                <p class="text-xs text-cream-700">Funeral home / Legacy.com / newspaper link.</p>
                <input
                  type="url"
                  name="obituaryUrl"
                  placeholder="https://www.legacy.com/…"
                  class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 placeholder-cream-500 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
                />
              </label>

              <label class="block sm:col-span-2">
                <span class="block text-sm font-semibold text-brand-900">Photo URL <span class="font-normal text-cream-700">(optional)</span></span>
                <input
                  type="url"
                  name="photoUrl"
                  placeholder="https://…"
                  class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 placeholder-cream-500 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
                />
              </label>

              <label class="block sm:col-span-2">
                <span class="block text-sm font-semibold text-brand-900">Tribute <span class="font-normal text-cream-700">(optional)</span></span>
                <textarea
                  name="tribute"
                  rows="4"
                  class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 placeholder-cream-500 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
                ></textarea>
              </label>
            </div>
          </div>
        </div>
      </form>
      <footer class="flex items-center justify-end gap-3 border-t border-cream-300 bg-cream-100/50 px-6 py-3">
        <p id="classmate-modal-message" class="mr-auto hidden text-sm"></p>
        <button
          type="button"
          id="classmate-modal-cancel"
          class="rounded-full border border-cream-400 bg-white px-4 py-1.5 text-sm font-medium text-brand-700 transition-colors hover:border-brand-500 hover:text-brand-900"
        >
          Cancel
        </button>
        <button
          type="submit"
          form="classmate-modal-form"
          id="classmate-modal-submit"
          class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-5 py-1.5 text-sm font-semibold text-cream-50 shadow-[0_2px_0_rgba(13,11,10,0.04),0_6px_14px_-6px_rgba(242,105,1,0.5)] transition-all duration-200 hover:bg-brand-600 hover:-translate-y-0.5"
        >
          <span id="classmate-modal-submit-label">Save classmate</span>
        </button>
      </footer>
    </div>
  </div>

  <!-- MERGE MODAL -->
  <div
    id="merge-modal"
    class="hidden fixed inset-0 items-center justify-center p-4"
    style="z-index: 200;"
    role="dialog"
    aria-modal="true"
    aria-labelledby="merge-modal-title"
  >
    <div id="merge-modal-backdrop" class="absolute inset-0 bg-brand-900/55"></div>
    <div class="relative flex max-h-[88vh] w-full max-w-2xl flex-col overflow-hidden rounded-2xl border border-cream-300 bg-cream-50 shadow-2xl">
      <header class="border-b border-cream-300 px-6 py-4">
        <p class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.22em] text-brand-700">Merge into</p>
        <h2 id="merge-modal-title" class="mt-1 font-heading text-xl font-semibold text-brand-900">—</h2>
        <p class="mt-1 text-xs text-cream-700">Pick the duplicate record to fold into this one.</p>
      </header>
      <div class="border-b border-rose-200 bg-rose-50 px-6 py-3 text-sm text-rose-800">
        <strong>Warning:</strong> the record you pick below will be permanently deleted.
        Any field on both records keeps <strong id="merge-modal-keep-name">the original</strong>'s value;
        missing fields and notes are copied over from the deleted one.
      </div>
      <div class="px-6 py-4">
        <input
          type="text"
          id="merge-modal-filter"
          placeholder="Filter by name…"
          class="block w-full rounded-full border-2 border-cream-300 bg-white px-4 py-2 text-sm text-brand-900 placeholder-cream-500 transition-colors duration-150 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
        />
      </div>
      <div id="merge-modal-list" class="flex-1 overflow-y-auto border-t border-cream-200"></div>
      <footer class="flex items-center justify-between gap-3 border-t border-cream-300 bg-cream-100/50 px-6 py-3">
        <span id="merge-modal-count" class="font-mono text-[0.62rem] uppercase tracking-[0.2em] text-cream-700"></span>
        <button
          type="button"
          id="merge-modal-close"
          class="rounded-full border border-cream-400 bg-white px-4 py-1.5 text-sm font-medium text-brand-700 transition-colors hover:border-brand-500 hover:text-brand-900"
        >
          Cancel
        </button>
      </footer>
    </div>
  </div>

  {unmatched.length > 0 && (
    <section class="mb-12">
      <header class="mb-4 flex items-baseline justify-between gap-3">
        <h2 class="font-heading text-lg font-semibold uppercase tracking-[0.08em] text-brand-900 sm:text-xl">Unmatched RSVPs</h2>
        <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-cream-700">{unmatched.length} mismatch{unmatched.length === 1 ? '' : 'es'}</span>
      </header>
      <p class="mb-3 text-sm text-cream-700">
        These RSVP submissions don't match any roster name (even with preferred name).
        Add a preferred name to a roster row, fix a typo, or add the missing classmate.
      </p>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>RSVP name</th>
              <th>Status</th>
              <th>Email</th>
            </tr>
          </thead>
          <tbody>
            {unmatched.map((u) => (
              <tr>
                <td><span class="font-semibold">{u.FullName}</span></td>
                <td>
                  {u.Attending === 'yes'   ? <span class="pill yes">✓ Yes</span>
                  : u.Attending === 'maybe' ? <span class="pill maybe">? Maybe</span>
                  : <span class="pill no">✗ No</span>}
                </td>
                <td class="mono dim">{u.Email}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}
</AdminLayout>

<script is:inline>
  (function () {
    const filter = document.getElementById('roster-filter');

    // Add/edit modal
    const cmModal = document.getElementById('classmate-modal');
    const cmBackdrop = document.getElementById('classmate-modal-backdrop');
    const cmCancel = document.getElementById('classmate-modal-cancel');
    const cmForm = document.getElementById('classmate-modal-form');
    const cmTitle = document.getElementById('classmate-modal-title');
    const cmKicker = document.getElementById('classmate-modal-kicker');
    const cmSubmitLabel = document.getElementById('classmate-modal-submit-label');
    const cmMessage = document.getElementById('classmate-modal-message');
    const cmAddBtn = document.getElementById('classmate-add-btn');

    // Merge modal
    const mergeModal = document.getElementById('merge-modal');
    const mergeModalBackdrop = document.getElementById('merge-modal-backdrop');
    const mergeModalClose = document.getElementById('merge-modal-close');
    const mergeModalTitle = document.getElementById('merge-modal-title');
    const mergeModalKeepName = document.getElementById('merge-modal-keep-name');
    const mergeModalFilter = document.getElementById('merge-modal-filter');
    const mergeModalList = document.getElementById('merge-modal-list');
    const mergeModalCount = document.getElementById('merge-modal-count');

    let mergePrimaryId = null;

    function setMessage(el, text, tone) {
      el.textContent = text;
      el.classList.remove('hidden', 'text-brand-700', 'text-rose-700', 'text-emerald-700');
      el.classList.add(
        tone === 'error' ? 'text-rose-700' :
        tone === 'ok'    ? 'text-emerald-700' :
                           'text-brand-700',
      );
    }

    const cmMemorialSection = document.getElementById('cm-memorial-section');
    const cmDeceasedCb = document.getElementById('cm-deceased-cb');
    function syncMemorialVisibility() {
      cmMemorialSection?.classList.toggle('hidden', !cmDeceasedCb?.checked);
    }
    cmDeceasedCb?.addEventListener('change', syncMemorialVisibility);

    // -------- Add/Edit modal --------
    function openClassmateModal(data) {
      cmForm.reset();
      cmMessage.classList.add('hidden');
      if (data) {
        cmKicker.textContent = `Editing #${data.id}`;
        cmTitle.textContent = data.fullName || 'Edit classmate';
        cmSubmitLabel.textContent = 'Update classmate';
        cmForm.elements.id.value = data.id;
        cmForm.elements.fullName.value = data.fullName ?? '';
        cmForm.elements.maidenName.value = data.maidenName ?? '';
        cmForm.elements.preferredFirstName.value = data.preferredFirstName ?? '';
        cmForm.elements.email.value = data.email ?? '';
        cmForm.elements.notes.value = data.notes ?? '';
        cmForm.elements.isDeceased.checked = !!data.isDeceased;
        cmForm.elements.birthYear.value   = data.birthYear   ?? '';
        cmForm.elements.passingYear.value = data.passingYear ?? '';
        cmForm.elements.tribute.value     = data.tribute     ?? '';
        cmForm.elements.photoUrl.value    = data.photoUrl    ?? '';
        cmForm.elements.obituaryUrl.value = data.obituaryUrl ?? '';
      } else {
        cmKicker.textContent = 'Roster';
        cmTitle.textContent = 'Add classmate';
        cmSubmitLabel.textContent = 'Save classmate';
        cmForm.elements.id.value = '';
      }
      syncMemorialVisibility();
      cmModal.classList.remove('hidden');
      cmModal.classList.add('flex');
      setTimeout(() => cmForm.elements.fullName.focus(), 0);
    }

    function closeClassmateModal() {
      cmModal.classList.add('hidden');
      cmModal.classList.remove('flex');
    }

    cmAddBtn?.addEventListener('click', () => openClassmateModal(null));
    cmCancel.addEventListener('click', closeClassmateModal);
    cmBackdrop.addEventListener('click', closeClassmateModal);

    cmForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(cmForm);
      const id = fd.get('id');
      const payload = {
        ...(id ? { id: Number(id) } : {}),
        fullName: fd.get('fullName'),
        maidenName: fd.get('maidenName'),
        preferredFirstName: fd.get('preferredFirstName'),
        email: fd.get('email'),
        notes: fd.get('notes'),
        isDeceased: fd.get('isDeceased') === 'on',
        birthYear:   fd.get('birthYear')   ? Number(fd.get('birthYear'))   : null,
        passingYear: fd.get('passingYear') ? Number(fd.get('passingYear')) : null,
        tribute:     fd.get('tribute'),
        photoUrl:    fd.get('photoUrl'),
        obituaryUrl: fd.get('obituaryUrl'),
      };
      setMessage(cmMessage, 'Saving…', 'info');
      try {
        const res = await fetch('/api/admin/classmates', {
          method: id ? 'PATCH' : 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const body = await res.json().catch(() => ({}));
        if (!res.ok) {
          setMessage(cmMessage, body && body.error ? body.error : `Failed (${res.status})`, 'error');
          return;
        }
        setMessage(cmMessage, 'Saved · reloading', 'ok');
        setTimeout(() => location.reload(), 400);
      } catch {
        setMessage(cmMessage, 'Network error.', 'error');
      }
    });

    // -------- Merge modal --------
    function escapeHtml(s) {
      return String(s ?? '').replace(/[&<>"']/g, (c) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
      }[c]));
    }

    function openMergeModal(primaryId, primaryName) {
      mergePrimaryId = primaryId;
      mergeModalTitle.textContent = primaryName;
      mergeModalKeepName.textContent = primaryName;
      mergeModalFilter.value = '';

      // Build the candidate list from every other row in the table.
      const items = [];
      document.querySelectorAll('tr[data-classmate-id]').forEach((row) => {
        const id = Number(row.getAttribute('data-classmate-id'));
        if (id === primaryId) return;
        const data = JSON.parse(row.getAttribute('data-classmate') || '{}');
        const yearbook = data.maidenName ? `${(data.fullName || '').split(/\s+/)[0]} ${data.maidenName}` : '';
        const meta = [yearbook && yearbook.toLowerCase() !== (data.fullName || '').toLowerCase() ? `yearbook: ${yearbook}` : '',
                      data.email,
                      data.notes ? data.notes.replace(/\s+/g, ' ').slice(0, 80) : '']
                     .filter(Boolean).join(' · ');
        items.push({ id, name: data.fullName, meta, hay: `${data.fullName} ${data.maidenName ?? ''} ${data.preferredFirstName ?? ''} ${data.email ?? ''}`.toLowerCase() });
      });

      mergeModalList.innerHTML = items.map((it) => `
        <button
          type="button"
          class="merge-pick-btn flex w-full flex-col items-start gap-0.5 border-b border-cream-200 px-6 py-3 text-left transition-colors hover:bg-brand-50/70 focus:bg-brand-50 focus:outline-none"
          data-merge-id="${it.id}"
          data-merge-name="${escapeHtml(it.name)}"
          data-hay="${escapeHtml(it.hay)}"
        >
          <span class="font-semibold text-brand-900">${escapeHtml(it.name)}</span>
          ${it.meta ? `<span class="font-mono text-[0.65rem] uppercase tracking-[0.18em] text-cream-700">${escapeHtml(it.meta)}</span>` : ''}
        </button>
      `).join('') || `<p class="px-6 py-8 text-center text-sm text-cream-700">No other classmates to merge.</p>`;
      mergeModalCount.textContent = items.length === 1 ? '1 candidate' : `${items.length} candidates`;

      mergeModalList.querySelectorAll('.merge-pick-btn').forEach((btn) => {
        btn.addEventListener('click', () => pickMergeTarget(
          Number(btn.getAttribute('data-merge-id')),
          btn.getAttribute('data-merge-name') || ''
        ));
      });

      mergeModal.classList.remove('hidden');
      mergeModal.classList.add('flex');
      // Focus the filter so admins can immediately type.
      setTimeout(() => mergeModalFilter.focus(), 0);
    }

    function closeMergeModal() {
      mergePrimaryId = null;
      mergeModal.classList.add('hidden');
      mergeModal.classList.remove('flex');
      mergeModalList.innerHTML = '';
    }

    async function pickMergeTarget(mergeId, mergeName) {
      if (mergePrimaryId === null) return;
      const keepName = mergeModalTitle.textContent || 'the kept record';
      if (!confirm(`Merge "${mergeName}" into "${keepName}"?\n\n` +
                   `"${mergeName}" will be permanently deleted.\n` +
                   `Field conflicts keep "${keepName}"'s values; missing fields and notes are copied over.\n\n` +
                   `This can't be undone.`)) {
        return;
      }
      const res = await fetch('/api/admin/classmates/merge', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ primaryId: mergePrimaryId, mergeId }),
      });
      if (res.ok) {
        location.reload();
      } else {
        const body = await res.json().catch(() => ({}));
        alert(body && body.error ? body.error : `Merge failed (${res.status})`);
      }
    }

    mergeModalClose.addEventListener('click', closeMergeModal);
    mergeModalBackdrop.addEventListener('click', closeMergeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      if (!mergeModal.classList.contains('hidden')) closeMergeModal();
      else if (!cmModal.classList.contains('hidden')) closeClassmateModal();
    });
    mergeModalFilter.addEventListener('input', () => {
      const q = mergeModalFilter.value.trim().toLowerCase();
      let shown = 0;
      mergeModalList.querySelectorAll('.merge-pick-btn').forEach((btn) => {
        const hay = btn.getAttribute('data-hay') || '';
        const match = !q || hay.includes(q);
        btn.style.display = match ? '' : 'none';
        if (match) shown += 1;
      });
      mergeModalCount.textContent = q
        ? `${shown} of ${mergeModalList.querySelectorAll('.merge-pick-btn').length} matching`
        : `${shown} candidate${shown === 1 ? '' : 's'}`;
    });

    document.querySelectorAll('tr[data-classmate-id]').forEach((row) => {
      const data = JSON.parse(row.getAttribute('data-classmate') || '{}');
      row.querySelector('.edit-btn')?.addEventListener('click', () => openClassmateModal(data));

      row.querySelector('.delete-btn')?.addEventListener('click', async (e) => {
        const btn = e.currentTarget;
        const name = btn.getAttribute('data-name');
        if (!confirm(`Remove ${name} from the roster?`)) return;
        const res = await fetch(`/api/admin/classmates?id=${encodeURIComponent(data.id)}`, { method: 'DELETE' });
        if (res.ok) location.reload();
        else {
          const body = await res.json().catch(() => ({}));
          alert(body && body.error ? body.error : `Failed (${res.status})`);
        }
      });

      row.querySelector('.merge-btn')?.addEventListener('click', () => {
        openMergeModal(data.id, data.fullName);
      });
    });

    // Filter
    filter.addEventListener('input', () => {
      const q = filter.value.trim().toLowerCase();
      document.querySelectorAll('tr[data-search]').forEach((row) => {
        const hay = row.getAttribute('data-search') || '';
        row.style.display = !q || hay.includes(q) ? '' : 'none';
      });
    });
  })();
</script>
