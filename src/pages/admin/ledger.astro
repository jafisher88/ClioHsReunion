---
import Layout from '../../layouts/Layout.astro';
import { env } from 'cloudflare:workers';
import { getAdmin, redirectToLogin } from '../../lib/admin-auth';

const admin = await getAdmin(Astro.request, env);
if (!admin) {
  return redirectToLogin(Astro.request);
}

interface LedgerRow {
  Id: number;
  EntryDate: string;
  Direction: 'in' | 'out';
  AmountCents: number;
  Category: string;
  Counterparty: string | null;
  Description: string | null;
  Method: string | null;
  Notes: string | null;
  CreatedBy: string;
  CreatedAt: string;
}

const [entriesResult, totalsResult] = await Promise.all([
  env.DB
    .prepare(
      `SELECT Id, EntryDate, Direction, AmountCents, Category, Counterparty,
              Description, Method, Notes, CreatedBy, CreatedAt
         FROM LedgerEntries
         ORDER BY EntryDate DESC, Id DESC`
    )
    .all<LedgerRow>(),
  env.DB
    .prepare(
      `SELECT
         COALESCE(SUM(CASE WHEN Direction = 'in'  THEN AmountCents ELSE 0 END), 0) AS InCents,
         COALESCE(SUM(CASE WHEN Direction = 'out' THEN AmountCents ELSE 0 END), 0) AS OutCents,
         COUNT(*) AS Total
       FROM LedgerEntries`
    )
    .first<{ InCents: number; OutCents: number; Total: number }>(),
]);

const entries = entriesResult.results ?? [];
const totals = totalsResult ?? { InCents: 0, OutCents: 0, Total: 0 };
const netCents = totals.InCents - totals.OutCents;

function fmtMoney(cents: number): string {
  const sign = cents < 0 ? '-' : '';
  const abs = Math.abs(cents);
  const whole = Math.floor(abs / 100);
  const frac = (abs % 100).toString().padStart(2, '0');
  // Insert thousands separators in the whole part
  const wholeWithSep = whole.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  return `${sign}$${wholeWithSep}.${frac}`;
}

function fmtDate(iso: string): string {
  const m = iso.match(/(\d{4})-(\d{2})-(\d{2})/);
  if (!m) return iso;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[Number(m[2]) - 1]} ${Number(m[3])}, ${m[1]}`;
}

const today = new Date().toISOString().slice(0, 10);

const inCategories = ['Contribution', 'Ticket', 'Reimbursement received', 'Other income'];
const outCategories = ['Venue', 'Food', 'Drinks', 'DJ', 'Photo booth', 'Decorations', 'Supplies', 'Refund issued', 'Other expense'];
const methods = ['Venmo', 'PayPal', 'Zelle', 'Cash', 'Check', 'Card', 'Other'];

const thClass = 'px-3 py-2 text-left text-xs font-semibold uppercase tracking-wider text-cream-800';
const tdClass = 'px-3 py-2 align-top';
---

<Layout title="Ledger">
  <div class="space-y-10">
    <header class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="font-script text-2xl text-accent-600">Money in &amp; out</p>
        <h1 class="mt-2 font-heading text-4xl uppercase tracking-wider text-brand-800 sm:text-5xl">Ledger</h1>
        <p class="mt-3 text-sm text-brand-700">{totals.Total} entries · running balance updates live as you add rows.</p>
      </div>
      <div class="flex flex-col items-end gap-1 text-sm">
        <span class="text-cream-700">Signed in as <span class="font-semibold text-brand-800">{admin.email}</span></span>
        <div class="flex gap-3">
          <a href="/admin/" class="text-brand-700 underline hover:text-brand-900">← Dashboard</a>
          <a href="/admin/admins" class="text-brand-700 underline hover:text-brand-900">Admins</a>
          <a href="/admin/logout" class="text-brand-700 underline hover:text-brand-900">Logout</a>
        </div>
      </div>
    </header>

    <section class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      <div class="rounded-xl border-2 border-emerald-200 bg-emerald-50 p-5">
        <div class="text-xs font-semibold uppercase tracking-wider text-emerald-800">Money in</div>
        <div class="mt-1 font-heading text-3xl text-emerald-900 tabular-nums">{fmtMoney(totals.InCents)}</div>
      </div>
      <div class="rounded-xl border-2 border-rose-200 bg-rose-50 p-5">
        <div class="text-xs font-semibold uppercase tracking-wider text-rose-800">Money out</div>
        <div class="mt-1 font-heading text-3xl text-rose-900 tabular-nums">{fmtMoney(totals.OutCents)}</div>
      </div>
      <div class={`rounded-xl border-2 p-5 ${netCents >= 0 ? 'border-brand-300 bg-brand-50' : 'border-rose-300 bg-rose-50'}`}>
        <div class={`text-xs font-semibold uppercase tracking-wider ${netCents >= 0 ? 'text-brand-700' : 'text-rose-800'}`}>Net balance</div>
        <div class={`mt-1 font-heading text-3xl tabular-nums ${netCents >= 0 ? 'text-brand-900' : 'text-rose-900'}`}>{fmtMoney(netCents)}</div>
        <div class="mt-1 text-xs text-cream-700">{netCents >= 0 ? 'In the black' : 'Need to cover this gap'}</div>
      </div>
    </section>

    <section class="rounded-2xl border-2 border-cream-300 bg-white p-6 shadow-sm">
      <h2 class="font-heading text-xl uppercase tracking-wider text-brand-800">Add an entry</h2>
      <form id="add-form" class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-6">
        <div class="sm:col-span-2">
          <label class="block text-xs font-semibold uppercase tracking-wider text-cream-800">Direction</label>
          <div class="mt-1 grid grid-cols-2 gap-2">
            <label class="cursor-pointer">
              <input type="radio" name="direction" value="in" required class="peer sr-only" checked />
              <span class="block rounded-lg border-2 border-cream-300 bg-white px-3 py-2 text-center text-sm font-medium text-brand-700 peer-checked:border-emerald-500 peer-checked:bg-emerald-50 peer-checked:text-emerald-800">
                Money in
              </span>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="direction" value="out" class="peer sr-only" />
              <span class="block rounded-lg border-2 border-cream-300 bg-white px-3 py-2 text-center text-sm font-medium text-brand-700 peer-checked:border-rose-500 peer-checked:bg-rose-50 peer-checked:text-rose-800">
                Money out
              </span>
            </label>
          </div>
        </div>

        <div class="sm:col-span-2">
          <label class="block text-xs font-semibold uppercase tracking-wider text-cream-800">Date</label>
          <input
            type="date"
            name="entryDate"
            required
            value={today}
            class="mt-1 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2 text-brand-900 focus:border-brand-500 focus:outline-none"
          />
        </div>

        <div class="sm:col-span-2">
          <label class="block text-xs font-semibold uppercase tracking-wider text-cream-800">Amount ($)</label>
          <input
            type="number"
            name="amount"
            step="0.01"
            min="0.01"
            required
            placeholder="50.00"
            inputmode="decimal"
            class="mt-1 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2 text-brand-900 placeholder-cream-500 focus:border-brand-500 focus:outline-none tabular-nums"
          />
        </div>

        <div class="sm:col-span-3">
          <label class="block text-xs font-semibold uppercase tracking-wider text-cream-800">Category</label>
          <input
            type="text"
            name="category"
            required
            list="category-list"
            placeholder="Pick or type one"
            class="mt-1 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2 text-brand-900 placeholder-cream-500 focus:border-brand-500 focus:outline-none"
          />
          <datalist id="category-list">
            {inCategories.map(c => <option value={c} />)}
            {outCategories.map(c => <option value={c} />)}
          </datalist>
        </div>

        <div class="sm:col-span-3">
          <label class="block text-xs font-semibold uppercase tracking-wider text-cream-800">From / To</label>
          <input
            type="text"
            name="counterparty"
            placeholder="Name of payer or vendor"
            class="mt-1 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2 text-brand-900 placeholder-cream-500 focus:border-brand-500 focus:outline-none"
          />
        </div>

        <div class="sm:col-span-4">
          <label class="block text-xs font-semibold uppercase tracking-wider text-cream-800">Description</label>
          <input
            type="text"
            name="description"
            placeholder="What was this for?"
            class="mt-1 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2 text-brand-900 placeholder-cream-500 focus:border-brand-500 focus:outline-none"
          />
        </div>

        <div class="sm:col-span-2">
          <label class="block text-xs font-semibold uppercase tracking-wider text-cream-800">Method</label>
          <input
            type="text"
            name="method"
            list="method-list"
            placeholder="Venmo, cash, …"
            class="mt-1 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2 text-brand-900 placeholder-cream-500 focus:border-brand-500 focus:outline-none"
          />
          <datalist id="method-list">
            {methods.map(m => <option value={m} />)}
          </datalist>
        </div>

        <div class="sm:col-span-6">
          <label class="block text-xs font-semibold uppercase tracking-wider text-cream-800">Notes (optional)</label>
          <textarea
            name="notes"
            rows="2"
            placeholder="Anything else worth remembering"
            class="mt-1 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2 text-brand-900 placeholder-cream-500 focus:border-brand-500 focus:outline-none"
          ></textarea>
        </div>

        <div class="sm:col-span-6 flex flex-wrap items-center gap-3">
          <button
            type="submit"
            class="rounded-full bg-brand-500 px-6 py-2.5 text-sm font-semibold text-cream-50 hover:bg-brand-600 disabled:opacity-60"
          >
            Add entry
          </button>
          <p id="add-message" class="hidden text-sm"></p>
        </div>
      </form>
    </section>

    <section>
      <h2 class="font-heading text-xl uppercase tracking-wider text-brand-800">All entries</h2>
      {entries.length === 0 ? (
        <p class="mt-3 text-sm text-cream-700">No entries yet. Add your first above.</p>
      ) : (
        <div class="mt-4 overflow-x-auto rounded-xl border border-cream-300 bg-white">
          <table class="min-w-full divide-y divide-cream-200 text-sm">
            <thead class="bg-cream-100">
              <tr>
                <th class={thClass}>Date</th>
                <th class={thClass}>Dir</th>
                <th class={thClass}>Category</th>
                <th class={thClass}>From / To</th>
                <th class={thClass}>Description</th>
                <th class={`${thClass} text-right`}>Amount</th>
                <th class={thClass}>Method</th>
                <th class={thClass}>By</th>
                <th class={thClass}></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-cream-200">
              {entries.map(e => (
                <tr>
                  <td class={`${tdClass} whitespace-nowrap text-cream-800`}>{fmtDate(e.EntryDate)}</td>
                  <td class={tdClass}>
                    {e.Direction === 'in' ? (
                      <span class="inline-flex rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-semibold text-emerald-800">IN</span>
                    ) : (
                      <span class="inline-flex rounded-full bg-rose-100 px-2 py-0.5 text-xs font-semibold text-rose-800">OUT</span>
                    )}
                  </td>
                  <td class={`${tdClass} font-semibold text-brand-800`}>{e.Category}</td>
                  <td class={`${tdClass} text-cream-800`}>{e.Counterparty ?? ''}</td>
                  <td class={`${tdClass} max-w-xs whitespace-pre-wrap text-cream-800`}>
                    {e.Description ?? ''}
                    {e.Notes && <div class="mt-1 text-xs text-cream-700">{e.Notes}</div>}
                  </td>
                  <td class={`${tdClass} whitespace-nowrap text-right tabular-nums font-semibold ${e.Direction === 'in' ? 'text-emerald-800' : 'text-rose-800'}`}>
                    {e.Direction === 'in' ? '+' : '−'}{fmtMoney(e.AmountCents)}
                  </td>
                  <td class={`${tdClass} text-cream-700`}>{e.Method ?? ''}</td>
                  <td class={`${tdClass} whitespace-nowrap text-xs text-cream-700`}>{e.CreatedBy.split('@')[0]}</td>
                  <td class={`${tdClass} text-right`}>
                    <button
                      type="button"
                      class="delete-btn rounded-full border border-rose-300 px-3 py-1 text-xs font-semibold text-rose-700 hover:border-rose-500 hover:bg-rose-50"
                      data-id={e.Id}
                    >
                      Delete
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>
  </div>
</Layout>

<script is:inline>
  const form = document.getElementById('add-form');
  const message = document.getElementById('add-message');

  function setMessage(text, tone) {
    message.textContent = text;
    message.classList.remove('hidden', 'text-brand-700', 'text-rose-700', 'text-emerald-700');
    message.classList.add(
      tone === 'error' ? 'text-rose-700' : tone === 'ok' ? 'text-emerald-700' : 'text-brand-700',
    );
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const payload = {
      direction: fd.get('direction'),
      entryDate: fd.get('entryDate'),
      amount: fd.get('amount'),
      category: fd.get('category'),
      counterparty: fd.get('counterparty'),
      description: fd.get('description'),
      method: fd.get('method'),
      notes: fd.get('notes'),
    };
    setMessage('Saving…', 'info');
    try {
      const res = await fetch('/api/admin/ledger', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const body = await res.json().catch(() => ({}));
      if (!res.ok) {
        setMessage(body && body.error ? body.error : `Failed (${res.status})`, 'error');
        return;
      }
      setMessage('Added. Reloading…', 'ok');
      setTimeout(() => location.reload(), 500);
    } catch {
      setMessage('Network error.', 'error');
    }
  });

  document.querySelectorAll('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      if (!id) return;
      if (!confirm('Delete this entry? This cannot be undone.')) return;
      const res = await fetch(`/api/admin/ledger?id=${encodeURIComponent(id)}`, { method: 'DELETE' });
      if (res.ok) {
        location.reload();
      } else {
        const body = await res.json().catch(() => ({}));
        alert(body && body.error ? body.error : `Failed (${res.status})`);
      }
    });
  });
</script>
