---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { getAdmin, loginUrlFor } from '../../lib/admin-auth';

const admin = await getAdmin(Astro.request, env);
if (!admin) {
  return Astro.redirect(loginUrlFor(Astro.request));
}

interface LedgerRow {
  Id: number;
  EntryDate: string;
  Direction: 'in' | 'out';
  AmountCents: number;
  Category: string;
  Counterparty: string | null;
  Description: string | null;
  Method: string | null;
  Notes: string | null;
  CreatedBy: string;
  CreatedAt: string;
}

const [entriesResult, totalsResult] = await Promise.all([
  env.DB
    .prepare(
      `SELECT Id, EntryDate, Direction, AmountCents, Category, Counterparty,
              Description, Method, Notes, CreatedBy, CreatedAt
         FROM LedgerEntries
         ORDER BY EntryDate DESC, Id DESC`
    )
    .all<LedgerRow>(),
  env.DB
    .prepare(
      `SELECT
         COALESCE(SUM(CASE WHEN Direction = 'in'  THEN AmountCents ELSE 0 END), 0) AS InCents,
         COALESCE(SUM(CASE WHEN Direction = 'out' THEN AmountCents ELSE 0 END), 0) AS OutCents,
         COUNT(*) AS Total,
         COALESCE(SUM(CASE WHEN Direction = 'in'  THEN 1 ELSE 0 END), 0) AS InCount,
         COALESCE(SUM(CASE WHEN Direction = 'out' THEN 1 ELSE 0 END), 0) AS OutCount
       FROM LedgerEntries`
    )
    .first<{ InCents: number; OutCents: number; Total: number; InCount: number; OutCount: number }>(),
]);

const entries = entriesResult.results ?? [];
const totals = totalsResult ?? { InCents: 0, OutCents: 0, Total: 0, InCount: 0, OutCount: 0 };
const netCents = totals.InCents - totals.OutCents;

function fmtMoney(cents: number): string {
  const sign = cents < 0 ? '-' : '';
  const abs = Math.abs(cents);
  const whole = Math.floor(abs / 100).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  const frac = (abs % 100).toString().padStart(2, '0');
  return `${sign}$${whole}.${frac}`;
}

function fmtDate(iso: string): string {
  const m = iso.match(/(\d{4})-(\d{2})-(\d{2})/);
  if (!m) return iso;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[Number(m[2]) - 1]} ${Number(m[3])}, ${m[1]}`;
}

const today = new Date().toISOString().slice(0, 10);

const inCategories = ['Contribution', 'Ticket', 'Reimbursement received', 'Other income'];
const outCategories = ['Venue', 'Food', 'Drinks', 'DJ', 'Photo booth', 'Decorations', 'Supplies', 'Refund issued', 'Other expense'];
const methods = ['Venmo', 'PayPal', 'Zelle', 'Cash', 'Check', 'Card', 'Other'];
---

<AdminLayout title="Ledger" adminEmail={admin.email}>
  <header class="mb-10 flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="font-script text-2xl text-accent-600">Money in &amp; out</p>
      <h1 class="mt-1 font-heading text-3xl font-bold uppercase tracking-[0.05em] text-brand-900 sm:text-4xl">Ledger</h1>
      <p class="mt-2 text-sm text-cream-700">
        {totals.Total} entries · running balance updates as you add rows.
      </p>
    </div>
  </header>

  <!-- POSITION SUMMARY -->
  <section class="mb-12">
    <header class="mb-4 flex items-baseline justify-between gap-3">
      <h2 class="font-heading text-lg font-semibold uppercase tracking-[0.08em] text-brand-900 sm:text-xl">Position</h2>
      <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-cream-700">live · USD</span>
    </header>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      <div class="admin-tile is-emerald">
        <div class="admin-tile-label">Money in</div>
        <div class="admin-tile-value">{fmtMoney(totals.InCents)}</div>
        <div class="admin-tile-sub">{totals.InCount} deposit{totals.InCount === 1 ? '' : 's'}</div>
      </div>
      <div class="admin-tile is-rose">
        <div class="admin-tile-label">Money out</div>
        <div class="admin-tile-value">{fmtMoney(totals.OutCents)}</div>
        <div class="admin-tile-sub">{totals.OutCount} expense{totals.OutCount === 1 ? '' : 's'}</div>
      </div>
      <div class:list={['admin-tile', netCents >= 0 ? 'is-brand' : 'is-rose']}>
        <div class="admin-tile-label">Net balance</div>
        <div class="admin-tile-value">{fmtMoney(netCents)}</div>
        <div class="admin-tile-sub">{netCents >= 0 ? 'In the black' : 'Need to cover this gap'}</div>
      </div>
    </div>
  </section>

  <!-- ADD ENTRY FORM -->
  <section class="mb-12">
    <header class="mb-4 flex items-baseline justify-between gap-3">
      <h2 class="font-heading text-lg font-semibold uppercase tracking-[0.08em] text-brand-900 sm:text-xl">Log entry</h2>
      <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-cream-700">stamps with {admin.email.split('@')[0]}</span>
    </header>
    <div class="rounded-2xl border border-cream-300 bg-white/80 p-6 shadow-soft sm:p-8">
      <form id="add-form" class="grid grid-cols-1 gap-5 sm:grid-cols-6">
        <fieldset class="sm:col-span-2">
          <legend class="block text-sm font-semibold text-brand-900">Direction <span class="text-brand-500">*</span></legend>
          <div class="mt-1.5 grid grid-cols-2 gap-2">
            <label class="group/r cursor-pointer">
              <input type="radio" name="direction" value="in" required checked class="peer sr-only" />
              <span class="block rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-center text-sm font-semibold text-cream-700 transition-all duration-150 group-hover/r:border-emerald-300 peer-checked:border-emerald-500 peer-checked:bg-emerald-50 peer-checked:text-emerald-800 peer-checked:shadow-[inset_0_0_0_1px_#10b981]">
                ▲ In
              </span>
            </label>
            <label class="group/r cursor-pointer">
              <input type="radio" name="direction" value="out" class="peer sr-only" />
              <span class="block rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-center text-sm font-semibold text-cream-700 transition-all duration-150 group-hover/r:border-rose-300 peer-checked:border-rose-500 peer-checked:bg-rose-50 peer-checked:text-rose-800 peer-checked:shadow-[inset_0_0_0_1px_#f43f5e]">
                ▼ Out
              </span>
            </label>
          </div>
        </fieldset>

        <label class="block sm:col-span-2">
          <span class="block text-sm font-semibold text-brand-900">Date <span class="text-brand-500">*</span></span>
          <input
            type="date"
            name="entryDate"
            required
            value={today}
            class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
          />
        </label>

        <label class="block sm:col-span-2">
          <span class="block text-sm font-semibold text-brand-900">Amount (USD) <span class="text-brand-500">*</span></span>
          <input
            type="number"
            name="amount"
            step="0.01"
            min="0.01"
            required
            placeholder="0.00"
            inputmode="decimal"
            class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 tabular-nums transition-colors duration-150 placeholder-cream-500 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
          />
        </label>

        <label class="block sm:col-span-3">
          <span class="block text-sm font-semibold text-brand-900">Category <span class="text-brand-500">*</span></span>
          <input
            type="text"
            name="category"
            list="category-list"
            required
            placeholder="Select or type"
            autocomplete="off"
            class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 placeholder-cream-500 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
          />
          <datalist id="category-list">
            {inCategories.map(c => <option value={c} />)}
            {outCategories.map(c => <option value={c} />)}
          </datalist>
        </label>

        <label class="block sm:col-span-3">
          <span class="block text-sm font-semibold text-brand-900">From / To</span>
          <input
            type="text"
            name="counterparty"
            placeholder="Payer or vendor name"
            autocomplete="off"
            class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 placeholder-cream-500 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
          />
        </label>

        <label class="block sm:col-span-4">
          <span class="block text-sm font-semibold text-brand-900">Description</span>
          <input
            type="text"
            name="description"
            placeholder="What was this for?"
            class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 placeholder-cream-500 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
          />
        </label>

        <label class="block sm:col-span-2">
          <span class="block text-sm font-semibold text-brand-900">Method</span>
          <input
            type="text"
            name="method"
            list="method-list"
            placeholder="Venmo, cash…"
            autocomplete="off"
            class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 placeholder-cream-500 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
          />
          <datalist id="method-list">
            {methods.map(m => <option value={m} />)}
          </datalist>
        </label>

        <label class="block sm:col-span-6">
          <span class="block text-sm font-semibold text-brand-900">Notes <span class="font-normal text-cream-700">(optional)</span></span>
          <textarea
            name="notes"
            rows="2"
            placeholder="Anything else worth remembering"
            class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 placeholder-cream-500 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
          ></textarea>
        </label>

        <div class="sm:col-span-6 flex flex-wrap items-center gap-3">
          <button
            type="submit"
            class="group/cta inline-flex items-center gap-2 rounded-full bg-brand-500 px-6 py-3 text-sm font-semibold text-cream-50 shadow-[0_2px_0_rgba(13,11,10,0.04),0_8px_18px_-6px_rgba(242,105,1,0.5)] transition-all duration-200 hover:bg-brand-600 hover:-translate-y-0.5"
          >
            Commit entry
            <span class="text-cream-50/70 transition-transform duration-200 group-hover/cta:translate-x-0.5" aria-hidden="true">→</span>
          </button>
          <p id="add-message" class="hidden text-sm"></p>
        </div>
      </form>
    </div>
  </section>

  <!-- LEDGER TABLE -->
  <section class="mb-12">
    <header class="mb-4 flex items-baseline justify-between gap-3">
      <h2 class="font-heading text-lg font-semibold uppercase tracking-[0.08em] text-brand-900 sm:text-xl">Entries</h2>
      <span class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-cream-700">newest first · {entries.length} rows</span>
    </header>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th class="num">#</th>
            <th>Date</th>
            <th>Dir</th>
            <th>Category</th>
            <th>From / To</th>
            <th>Description</th>
            <th class="num">Amount</th>
            <th>Method</th>
            <th>By</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {entries.length === 0 && (
            <tr class="empty-row"><td colspan="10">— no entries yet — log the first deposit above —</td></tr>
          )}
          {entries.map((e) => (
            <tr>
              <td class="num mono dim">#{e.Id}</td>
              <td class="mono dim whitespace-nowrap">{fmtDate(e.EntryDate)}</td>
              <td>
                {e.Direction === 'in'
                  ? <span class="pill in">▲ IN</span>
                  : <span class="pill out">▼ OUT</span>}
              </td>
              <td><span class="font-semibold">{e.Category}</span></td>
              <td class="dim">{e.Counterparty ?? '—'}</td>
              <td class="dim max-w-xs whitespace-pre-wrap">
                {e.Description ?? '—'}
                {e.Notes && <div class="mt-0.5 text-xs font-mono text-cream-600">↳ {e.Notes}</div>}
              </td>
              <td class:list={['num', 'mono', 'font-semibold', e.Direction === 'in' ? 'text-emerald-700' : 'text-rose-700']}>
                {e.Direction === 'in' ? '+' : '−'}{fmtMoney(e.AmountCents).replace('-', '')}
              </td>
              <td class="mono dim">{e.Method ?? '—'}</td>
              <td class="mono dim">{e.CreatedBy.split('@')[0]}</td>
              <td class="num">
                <button
                  type="button"
                  class="delete-btn rounded-full border border-rose-300 bg-white px-3 py-1 font-mono text-[0.62rem] font-semibold uppercase tracking-[0.18em] text-rose-700 transition-colors hover:border-rose-500 hover:bg-rose-50"
                  data-id={e.Id}
                >
                  Delete
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</AdminLayout>

<script is:inline>
  const form = document.getElementById('add-form');
  const message = document.getElementById('add-message');

  function setMessage(text, tone) {
    message.textContent = text;
    message.hidden = false;
    message.classList.remove('hidden');
    message.classList.remove('text-brand-700', 'text-rose-700', 'text-emerald-700');
    message.classList.add(
      tone === 'error' ? 'text-rose-700' : tone === 'ok' ? 'text-emerald-700' : 'text-brand-700',
    );
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const payload = {
      direction: fd.get('direction'),
      entryDate: fd.get('entryDate'),
      amount: fd.get('amount'),
      category: fd.get('category'),
      counterparty: fd.get('counterparty'),
      description: fd.get('description'),
      method: fd.get('method'),
      notes: fd.get('notes'),
    };
    setMessage('Committing…', 'info');
    try {
      const res = await fetch('/api/admin/ledger', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const body = await res.json().catch(() => ({}));
      if (!res.ok) {
        setMessage(body && body.error ? body.error : `Failed (${res.status})`, 'error');
        return;
      }
      setMessage('Entry committed · reloading', 'ok');
      setTimeout(() => location.reload(), 500);
    } catch {
      setMessage('Network error.', 'error');
    }
  });

  document.querySelectorAll('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      if (!id) return;
      if (!confirm(`Delete entry #${id}? This cannot be undone.`)) return;
      const res = await fetch(`/api/admin/ledger?id=${encodeURIComponent(id)}`, { method: 'DELETE' });
      if (res.ok) {
        location.reload();
      } else {
        const body = await res.json().catch(() => ({}));
        alert(body && body.error ? body.error : `Failed (${res.status})`);
      }
    });
  });
</script>
