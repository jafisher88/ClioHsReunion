---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
  <div class="mx-auto max-w-2xl">
    <header class="animate-fade-in">
      <p class="font-script text-2xl text-accent-600">Get in touch</p>
      <h1 class="mt-2 font-heading text-4xl uppercase tracking-wider text-brand-800 sm:text-5xl">Contact</h1>
      <p class="mt-4 text-brand-700">
        Questions about the reunion, suggestions, or want to help plan? Reach out.
      </p>
    </header>

    <div class="mt-10 space-y-4 animate-fade-up">
      <div class="rounded-2xl border-2 border-cream-300 bg-white/80 p-6 shadow-sm">
        <h2 class="font-heading text-lg uppercase tracking-wider text-brand-800">Planning crew</h2>
        <p class="mt-2 text-brand-700">
          The fastest way to reach us is the Facebook group — most messages get answered the same day.
        </p>
        <a
          href="https://www.facebook.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex rounded-full bg-brand-700 px-5 py-2 text-sm font-semibold text-cream-50 hover:bg-brand-800"
        >
          Open Facebook group →
        </a>
      </div>

      <div class="rounded-2xl border-2 border-cream-300 bg-white/80 p-6 shadow-sm">
        <h2 class="font-heading text-lg uppercase tracking-wider text-brand-800">Email</h2>
        <p class="mt-2 text-brand-700">
          Prefer email? Drop us a line and we'll get back to you.
        </p>
        <a
          href="mailto:hello@cliohsreunion.com"
          class="mt-4 inline-flex rounded-full border-2 border-brand-300 bg-white px-5 py-2 text-sm font-medium text-brand-700 hover:border-brand-500"
        >
          hello@cliohsreunion.com
        </a>
      </div>
    </div>
  </div>
</Layout>
