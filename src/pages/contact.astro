---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" folio="07" section="MEMO">
  <div class="page-opener reveal">
    <div class="page-opener-section">
      <span class="page-opener-kicker">Issue 07 · The Memo</span>
      <span class="page-opener-label">Contact.</span>
    </div>
    <div class="page-opener-meta">
      Inter-office<br />
      memorandum
    </div>
  </div>

  <article class="memo reveal delay-1">
    <header class="memo-head">
      <span class="memo-stamp">MEMORANDUM</span>
      <span class="memo-no">No. 07 · 2026</span>
    </header>

    <dl class="memo-fields">
      <div class="memo-field">
        <dt>FROM</dt>
        <dd>You, future reunion attendee.</dd>
      </div>
      <div class="memo-field">
        <dt>TO</dt>
        <dd>The Clio HS Class of 2006 planning crew.</dd>
      </div>
      <div class="memo-field">
        <dt>DATE</dt>
        <dd>Whenever you've got a minute.</dd>
      </div>
      <div class="memo-field">
        <dt>RE</dt>
        <dd>Questions, suggestions, or how to help plan the reunion.</dd>
      </div>
    </dl>

    <div class="memo-divider">
      <span>· · ·</span>
    </div>

    <div class="memo-body">
      <p>
        Questions about the reunion, suggestions, or want to help plan? The
        fastest way to reach us is the
        <strong>Class of 2006 Facebook group</strong> &mdash; most messages get
        answered the same day.
      </p>
    </div>

    <div class="memo-actions">
      <a
        href="https://www.facebook.com/share/g/1G2ZxKc1GP/?mibextid=wwXIfr"
        target="_blank"
        rel="noopener noreferrer"
        class="ticket-cta"
      >
        <span class="ticket-cta-body">Open Facebook group</span>
        <span class="ticket-cta-stub">↗</span>
      </a>
      <a href="/rsvp" class="outline-cta">
        Use the RSVP form notes field
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <footer class="memo-foot">
      <span class="memo-foot-stamp">RECEIVED</span>
      <span class="memo-foot-text">Filed under: Public Relations · Class of 2006</span>
    </footer>
  </article>
</Layout>

<style is:global>
  .memo {
    max-width: 56rem;
    margin: 1.5rem auto 0;
    background: var(--color-cream-50);
    border: 2px solid var(--color-brand-900);
    box-shadow: 8px 8px 0 var(--color-brand-900);
    padding: 2rem 2.25rem;
    position: relative;
  }
  .memo-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-bottom: 1rem;
    border-bottom: 2.5px solid var(--color-brand-900);
    margin-bottom: 1.5rem;
  }
  .memo-stamp {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 96, "wght" 700, "WONK" 1;
    font-style: italic;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    color: var(--color-brand-900);
    letter-spacing: -0.03em;
  }
  .memo-no {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: var(--color-cream-700);
  }
  .memo-fields {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin: 0;
  }
  .memo-field {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 1rem;
    align-items: baseline;
    border-bottom: 1px dotted rgba(13, 11, 10, 0.3);
    padding-bottom: 0.5rem;
  }
  .memo-field dt {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: var(--color-cream-700);
    font-weight: 600;
  }
  .memo-field dd {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 32, "wght" 500, "WONK" 1;
    font-size: 1.1rem;
    color: var(--color-brand-900);
    margin: 0;
    line-height: 1.3;
  }
  .memo-divider {
    text-align: center;
    margin: 1.5rem 0;
    font-family: var(--font-mono);
    color: var(--color-brand-500);
    letter-spacing: 0.4em;
  }
  .memo-body {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 24, "wght" 400, "WONK" 1;
    font-size: 1.15rem;
    line-height: 1.55;
    color: var(--color-brand-800);
    max-width: 40rem;
  }
  .memo-body strong {
    font-weight: 600;
    color: var(--color-brand-900);
  }
  .memo-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.5rem;
  }
  .memo-foot {
    margin-top: 2.5rem;
    padding-top: 1rem;
    border-top: 1.5px dashed var(--color-brand-900);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .memo-foot-stamp {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--color-redpen-500);
    border: 2px solid var(--color-redpen-500);
    padding: 0.3rem 0.6rem;
    transform: rotate(-3deg);
    background: rgba(193, 39, 45, 0.04);
    font-weight: 700;
  }
  .memo-foot-text {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-cream-700);
  }
</style>
