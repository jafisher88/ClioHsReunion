---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
  <div class="mx-auto max-w-2xl">
    <header class="reveal">
      <span class="section-kicker">Get in touch</span>
      <h1 class="mt-2 font-heading text-4xl font-bold uppercase tracking-[0.05em] text-brand-900 sm:text-5xl">Contact</h1>
      <p class="mt-5 leading-relaxed text-brand-700">
        Questions about the reunion, suggestions, or want to help plan? Reach out.
      </p>
    </header>

    <div class="reveal mt-10 space-y-4">
      <div class="rounded-2xl border border-cream-300 bg-white p-6 shadow-soft sm:p-8">
        <span class="section-kicker">Fastest way</span>
        <h2 class="mt-2 font-heading text-lg font-semibold uppercase tracking-[0.08em] text-brand-900 sm:text-xl">Planning crew on Facebook</h2>
        <p class="mt-3 leading-relaxed text-brand-700">
          The fastest way to reach us is the Facebook group — most messages get answered the same day.
        </p>
        <a
          href="https://www.facebook.com/share/g/1G2ZxKc1GP/?mibextid=wwXIfr"
          target="_blank"
          rel="noopener noreferrer"
          class="group/cta mt-5 inline-flex items-center gap-2 rounded-full bg-brand-500 px-5 py-2.5 text-sm font-semibold text-cream-50 shadow-[0_2px_0_rgba(13,11,10,0.04),0_8px_18px_-6px_rgba(242,105,1,0.5)] transition-all duration-200 hover:bg-brand-600 hover:-translate-y-0.5"
        >
          Open Facebook group
          <span class="text-cream-50/70 transition-transform duration-200 group-hover/cta:translate-x-0.5" aria-hidden="true">↗</span>
        </a>
      </div>

      <div class="rounded-2xl border border-cream-300 bg-white/70 p-6 shadow-soft sm:p-8">
        <span class="section-kicker">Alternative</span>
        <h2 class="mt-2 font-heading text-lg font-semibold uppercase tracking-[0.08em] text-brand-900 sm:text-xl">Not on Facebook?</h2>
        <p class="mt-3 leading-relaxed text-brand-700">
          Reach out through a classmate who is, or send your question via the
          <a href="/rsvp" class="font-medium text-brand-700 underline decoration-accent-400 decoration-2 underline-offset-4 hover:text-brand-900">RSVP form</a>
          — leave a note in the comments and we'll follow up.
        </p>
      </div>
    </div>
  </div>
</Layout>
