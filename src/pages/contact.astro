---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
  <div class="mx-auto max-w-2xl">
    <header class="reveal text-center">
      <span class="section-kicker mx-auto">Get in touch</span>
      <h1 class="mt-2 font-heading text-4xl font-bold uppercase tracking-[0.05em] text-brand-900 sm:text-5xl">
        Send the planning crew a note
      </h1>
      <p class="mx-auto mt-5 max-w-xl leading-relaxed text-brand-700">
        Pass along a classmate's email, flag a correction, share a memory, or ask
        a question. Submissions go straight to the planning crew — we'll follow
        up if needed.
      </p>
    </header>

    <div class="reveal mt-10 rounded-2xl border border-cream-300 bg-white p-6 shadow-soft sm:p-10">
      <form id="contact-form" class="space-y-5">
        <div>
          <label for="category" class="block text-sm font-semibold text-brand-900">
            What's this about? <span class="text-brand-500">*</span>
          </label>
          <select
            id="category"
            name="category"
            class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
          >
            <option value="general">General question</option>
            <option value="classmate-info">Classmate info / contact details</option>
            <option value="correction">Correction or update</option>
            <option value="memoriam">In memoriam tribute</option>
            <option value="photos-stories">Photos or stories</option>
            <option value="volunteer-help">Offer to help</option>
            <option value="other">Something else</option>
          </select>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          <label class="block">
            <span class="block text-sm font-semibold text-brand-900">Your name <span class="font-normal text-cream-700">(optional)</span></span>
            <input
              type="text"
              name="submitterName"
              class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
            />
          </label>
          <label class="block">
            <span class="block text-sm font-semibold text-brand-900">Email <span class="font-normal text-cream-700">(optional, if you want a reply)</span></span>
            <input
              type="email"
              name="submitterEmail"
              class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
            />
          </label>
        </div>

        <label class="block">
          <span class="block text-sm font-semibold text-brand-900">Subject <span class="font-normal text-cream-700">(optional)</span></span>
          <input
            type="text"
            name="subject"
            class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2.5 text-brand-900 transition-colors duration-150 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
          />
        </label>

        <label class="block">
          <span class="block text-sm font-semibold text-brand-900">
            Message <span class="text-brand-500">*</span>
          </span>
          <textarea
            name="message"
            rows={6}
            required
            class="mt-1.5 block w-full rounded-lg border-2 border-cream-300 bg-white px-3 py-2 text-brand-900 transition-colors duration-150 hover:border-cream-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/15"
          ></textarea>
        </label>

        {/* Honeypot field — hidden from humans, bots fill it. */}
        <div class="hidden" aria-hidden="true">
          <label>Leave blank
            <input type="text" name="hp" tabindex="-1" autocomplete="off" />
          </label>
        </div>

        <p id="contact-error" class="hidden rounded-lg border border-rose-300 bg-rose-50 px-4 py-3 text-sm text-rose-800"></p>

        <button
          type="submit"
          id="contact-submit"
          class="group/cta inline-flex w-full items-center justify-center gap-2 rounded-full bg-brand-500 px-6 py-3.5 text-base font-semibold text-cream-50 shadow-[0_2px_0_rgba(13,11,10,0.04),0_12px_24px_-8px_rgba(242,105,1,0.5)] transition-all duration-200 hover:bg-brand-600 hover:-translate-y-0.5 disabled:opacity-60 disabled:hover:translate-y-0"
        >
          <span id="contact-submit-label">Send to planning crew</span>
          <span class="transition-transform duration-200 group-hover/cta:translate-x-0.5" aria-hidden="true">→</span>
        </button>
      </form>

      <div id="contact-success" class="hidden text-center">
        <div class="mx-auto mb-3 inline-flex h-12 w-12 items-center justify-center rounded-full bg-accent-100 text-2xl">✓</div>
        <h2 class="font-heading text-2xl font-semibold uppercase tracking-[0.06em] text-brand-900">Thanks — we got it.</h2>
        <p class="mx-auto mt-3 max-w-md text-brand-700">
          Your note is in the planning crew's queue. If you left an email we'll be
          in touch when there's something to share.
        </p>
        <button
          id="contact-again"
          type="button"
          class="mt-6 inline-flex items-center gap-2 rounded-full border-2 border-brand-300 bg-white px-6 py-2.5 text-sm font-semibold text-brand-700 transition-all duration-200 hover:border-brand-500 hover:bg-brand-50 hover:-translate-y-0.5"
        >
          Send another
        </button>
      </div>
    </div>

    <div class="reveal mt-6 rounded-2xl border border-cream-300 bg-white/70 p-6 shadow-soft sm:p-8">
      <span class="section-kicker">Or join the conversation</span>
      <h2 class="mt-2 font-heading text-lg font-semibold uppercase tracking-[0.08em] text-brand-900 sm:text-xl">Class Facebook group</h2>
      <p class="mt-3 leading-relaxed text-brand-700">
        Most of the day-to-day chatter lives in the class Facebook group. Hop in
        to see what others are saying about the reunion.
      </p>
      <a
        href="https://www.facebook.com/share/g/1G2ZxKc1GP/?mibextid=wwXIfr"
        target="_blank"
        rel="noopener noreferrer"
        class="group/cta mt-5 inline-flex items-center gap-2 rounded-full border-2 border-brand-300 bg-white px-5 py-2.5 text-sm font-semibold text-brand-700 transition-all duration-200 hover:border-brand-500 hover:bg-brand-50 hover:-translate-y-0.5"
      >
        Open Facebook group
        <span class="transition-transform duration-200 group-hover/cta:translate-x-0.5" aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</Layout>

<script is:inline>
  (function () {
    const form = document.getElementById('contact-form');
    const errorEl = document.getElementById('contact-error');
    const submitBtn = document.getElementById('contact-submit');
    const submitLabel = document.getElementById('contact-submit-label');
    const successEl = document.getElementById('contact-success');
    const againBtn = document.getElementById('contact-again');

    function showError(msg) {
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
    }
    function clearError() {
      errorEl.classList.add('hidden');
      errorEl.textContent = '';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearError();
      submitBtn.disabled = true;
      submitLabel.textContent = 'Sending…';

      const fd = new FormData(form);
      const data = {
        category: String(fd.get('category') ?? 'general'),
        submitterName: String(fd.get('submitterName') ?? ''),
        submitterEmail: String(fd.get('submitterEmail') ?? ''),
        subject: String(fd.get('subject') ?? ''),
        message: String(fd.get('message') ?? ''),
        hp: String(fd.get('hp') ?? ''),
      };
      try {
        const res = await fetch('/api/submit-info', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const body = await res.json().catch(() => ({}));
        if (!res.ok) {
          showError(body && body.error ? body.error : `Could not send (${res.status}).`);
          submitBtn.disabled = false;
          submitLabel.textContent = 'Send to planning crew';
          return;
        }
        form.classList.add('hidden');
        successEl.classList.remove('hidden');
      } catch {
        showError('Network error — please try again.');
        submitBtn.disabled = false;
        submitLabel.textContent = 'Send to planning crew';
      }
    });

    againBtn.addEventListener('click', () => {
      form.reset();
      submitBtn.disabled = false;
      submitLabel.textContent = 'Send to planning crew';
      successEl.classList.add('hidden');
      form.classList.remove('hidden');
      clearError();
    });
  })();
</script>
