---
import Layout from '../layouts/Layout.astro';
import RsvpForm from '../components/RsvpForm.tsx';
---

<Layout title="RSVP">
  <div class="mx-auto max-w-2xl">
    <header class="animate-fade-in text-center">
      <p class="font-script text-2xl text-accent-600">Save your spot</p>
      <h1 class="mt-2 font-heading text-4xl uppercase tracking-wider text-brand-800 sm:text-5xl">RSVP</h1>
      <p class="mt-4 text-brand-700">
        A quick yes / no / maybe helps us plan headcount. You can update your response later
        by submitting again with the same email.
      </p>
    </header>

    <div class="mt-10 rounded-2xl border-2 border-cream-300 bg-white/80 p-6 shadow-sm sm:p-10 animate-fade-up">
      <RsvpForm client:load />
    </div>

    <p class="mt-8 text-center text-sm text-brand-600">
      Trouble with the form? Email the planning crew via <a href="/contact" class="underline hover:text-brand-800">the contact page</a>.
    </p>
  </div>
</Layout>
