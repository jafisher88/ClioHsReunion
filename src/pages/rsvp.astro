---
import Layout from '../layouts/Layout.astro';
import RsvpForm from '../components/RsvpForm.tsx';
---

<Layout title="RSVP">
  <div class="mx-auto max-w-2xl">
    <header class="reveal text-center">
      <span class="section-kicker mx-auto"><span class="mx-auto">Save your spot</span></span>
      <h1 class="mt-2 font-heading text-4xl font-bold uppercase tracking-[0.05em] text-brand-900 sm:text-5xl">RSVP</h1>
      <p class="mx-auto mt-5 max-w-xl text-brand-700 leading-relaxed">
        A quick yes / no / maybe helps us plan headcount. You can update your response later
        by submitting again with the same email.
      </p>
    </header>

    <div class="reveal mt-10 rounded-2xl border border-cream-300 bg-white p-6 shadow-soft sm:p-10">
      <RsvpForm client:load />
    </div>

    <p class="reveal mt-8 text-center text-sm text-brand-600">
      Trouble with the form? Email the planning crew via
      <a href="/contact" class="font-medium text-brand-700 underline decoration-accent-400 decoration-2 underline-offset-4 hover:text-brand-900">the contact page</a>.
    </p>
  </div>
</Layout>
