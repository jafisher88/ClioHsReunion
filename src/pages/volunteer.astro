---
import Layout from '../layouts/Layout.astro';
import VolunteerForm from '../components/VolunteerForm.tsx';
---

<Layout title="Volunteer">
  <div class="mx-auto max-w-2xl">
    <header class="reveal text-center">
      <span class="section-kicker mx-auto">Lend a hand</span>
      <h1 class="mt-2 font-heading text-4xl font-bold uppercase tracking-[0.05em] text-brand-900 sm:text-5xl">Volunteer</h1>
      <p class="mx-auto mt-5 max-w-xl text-brand-700 leading-relaxed">
        A reunion this good doesn't run itself. We need a few hands to set things up
        the day before and a few more to clean up the day after. Either one earns you
        bragging rights and the eternal thanks of the planning crew.
      </p>
    </header>

    <div class="reveal mt-10 rounded-2xl border border-cream-300 bg-white p-6 shadow-soft sm:p-10">
      <VolunteerForm client:load />
    </div>

    <p class="reveal mt-8 text-center text-sm italic text-brand-600">
      Already RSVP'd? Cool — you can still sign up to help, separate from your attendance.
    </p>
  </div>
</Layout>
