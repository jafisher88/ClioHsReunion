---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import Step from '../components/Step.astro';
---

<Layout title="Event" folio="02" section="THE PROGRAM">
  <div class="page-opener reveal">
    <div class="page-opener-section">
      <span class="page-opener-kicker">Issue 02 · The Program</span>
      <span class="page-opener-label">Event details.</span>
    </div>
    <div class="page-opener-meta">
      A program of the evening<br />
      &amp; the particulars
    </div>
  </div>

  <header class="event-intro reveal delay-1">
    <p class="pull-quote">
      We're putting the final touches on the schedule. Here's what we know so
      far — check back as details firm up, and follow the Facebook group for
      live updates.
    </p>
  </header>

  <!-- PARTICULARS -->
  <section>
    <div class="editorial-rule reveal delay-2">
      <span class="num">01</span>
      <span class="label">The particulars</span>
      <span class="line"></span>
      <span class="meta">date · venue · food · cost</span>
    </div>

    <div class="catalog-grid reveal delay-2">
      <div class="catalog-entry">
        <header class="catalog-entry-num"><span>i</span><span>Date</span></header>
        <h3 class="catalog-entry-label">November 2026.</h3>
        <p class="catalog-entry-value">
          The exact date is being voted on in the
          <a href="https://www.facebook.com/share/g/1G2ZxKc1GP/?mibextid=wwXIfr" target="_blank" rel="noopener noreferrer" class="event-link">Class of 2006 Facebook group</a>.
        </p>
        <p class="catalog-entry-meta">TBA · forthcoming</p>
      </div>

      <a
        href="https://www.google.com/maps/search/?api=1&query=Round+Em+Up+Ranch+Clio+MI"
        target="_blank"
        rel="noopener noreferrer"
        class="catalog-entry catalog-entry-link"
      >
        <header class="catalog-entry-num"><span>ii</span><span>Venue</span></header>
        <h3 class="catalog-entry-label">Round Em Up Ranch.</h3>
        <p class="catalog-entry-value">Clio, Michigan.</p>
        <p class="catalog-entry-meta">Open in Google Maps ↗</p>
      </a>

      <div class="catalog-entry">
        <header class="catalog-entry-num"><span>iii</span><span>Food &amp; drink</span></header>
        <h3 class="catalog-entry-label">Still being decided.</h3>
        <p class="catalog-entry-value">We'll share the plan once it's locked in.</p>
        <p class="catalog-entry-meta">Forthcoming</p>
      </div>

      <div class="catalog-entry">
        <header class="catalog-entry-num"><span>iv</span><span>Cost</span></header>
        <h3 class="catalog-entry-label">Open donation, for now.</h3>
        <p class="catalog-entry-value">
          We're still nailing down the per-head cost. In the meantime, donations
          of any size are welcome to help cover the costs.
        </p>
        <p class="catalog-entry-meta">
          Donate via Venmo to
          <a href="https://venmo.com/u/Jafisher88" target="_blank" rel="noopener noreferrer" class="event-link">@Jafisher88</a>
          (friends &amp; family).
        </p>
      </div>
    </div>
  </section>

  <!-- PROGRAM OF EVENTS -->
  <section class="reveal delay-3">
    <div class="editorial-rule">
      <span class="num">02</span>
      <span class="label">Tentative program</span>
      <span class="line"></span>
      <span class="meta">subject to change</span>
    </div>

    <ol class="program-list">
      <Step time="6:00 PM" title="Doors open">
        Sign in, grab a name tag (yes, you'll need one &mdash; 20 years is 20 years), say hi.
      </Step>
      <Step time="7:00 PM" title="Welcome">
        Quick welcome from the planning crew, then mingle.
      </Step>
      <Step time="7:30 PM" title="Toast &amp; memories">
        A toast to classmates we've lost, and a few yearbook throwbacks on the big screen.
      </Step>
      <Step time="8:00 PM" title="Music &amp; dancing">
        DJ takes over with a 2002&ndash;2006 playlist. Requests welcome.
      </Step>
      <Step time="All night" title="Photo booth">
        A photo booth runs the whole evening &mdash; every shot gets uploaded so you can grab the digital copies after.
      </Step>
      <Step time="11:00 PM" title="Last call">
        Hugs, photos, and &ldquo;let's not wait ten years next time.&rdquo;
      </Step>
    </ol>
  </section>

  <!-- READY TO RSVP -->
  <section class="reveal delay-4">
    <div class="rsvp-call">
      <div class="rsvp-call-body">
        <span class="rsvp-call-kicker">Ready when you are.</span>
        <h2 class="rsvp-call-h">RSVP &mdash; even a <em>maybe</em> helps us plan.</h2>
        <p class="rsvp-call-p">
          Even a tentative &ldquo;maybe&rdquo; helps us plan headcount with the venue.
          Takes about a minute.
        </p>
      </div>
      <a href="/rsvp" class="ticket-cta">
        <span class="ticket-cta-body">R.S.V.P.</span>
        <span class="ticket-cta-stub">→</span>
      </a>
    </div>
  </section>
</Layout>

<style is:global>
  .event-intro { max-width: 50rem; margin: 1rem 0 2rem; }
  .event-link {
    color: var(--color-brand-700);
    border-bottom: 1px solid var(--color-brand-500);
    text-decoration: none;
    font-weight: 500;
  }
  .event-link:hover { color: var(--color-brand-500); }

  .program-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .rsvp-call {
    margin-top: 3rem;
    padding: 2rem 2rem 2.25rem;
    background: var(--color-brand-900);
    color: var(--color-cream-50);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .rsvp-call::before {
    content: "";
    position: absolute;
    top: -40%;
    right: -10%;
    width: 60%;
    height: 180%;
    background: radial-gradient(circle, rgba(242, 105, 1, 0.18), transparent 60%);
    pointer-events: none;
  }
  @media (max-width: 720px) { .rsvp-call { grid-template-columns: 1fr; } }
  .rsvp-call-kicker {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.26em;
    color: var(--color-brand-400);
    font-weight: 600;
    display: block;
    margin-bottom: 0.75rem;
  }
  .rsvp-call-h {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 96, "wght" 600, "WONK" 1;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    line-height: 1.05;
    margin: 0;
    color: var(--color-cream-50);
    letter-spacing: -0.02em;
  }
  .rsvp-call-h em {
    font-style: italic;
    color: var(--color-brand-400);
    font-variation-settings: "opsz" 96, "wght" 600, "WONK" 1, "SOFT" 100;
  }
  .rsvp-call-p {
    font-family: var(--font-body);
    font-size: 1rem;
    color: rgba(253, 251, 246, 0.75);
    line-height: 1.5;
    margin: 1rem 0 0;
    max-width: 36rem;
  }
  .rsvp-call .ticket-cta { z-index: 1; }
</style>
