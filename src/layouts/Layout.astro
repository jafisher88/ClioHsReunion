---
import Logo from '../components/Logo.astro';
import MobileMenu from '../components/MobileMenu.tsx';

interface Props {
  title: string;
  description?: string;
  image?: string;
  folio?: string;       // page folio number, e.g. "01"
  section?: string;     // editorial section label, e.g. "HOMEPAGE"
}

const {
  title,
  description = 'Clio High School Class of 2006 — 20-year reunion. Event details, RSVP, and classmate links.',
  image,
  folio = '00',
  section,
} = Astro.props;

const pageTitle = title === 'Home' ? "Clio High School Class of 2006 — 20-Year Reunion" : `${title} | Clio High School Class of 2006`;
const ogImage = image || 'https://cliohsreunion.com/og.png';
const canonicalUrl = new URL(Astro.url.pathname, 'https://cliohsreunion.com').href;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const navLinks = [
  { href: '/',           num: '01', label: 'Home' },
  { href: '/event',      num: '02', label: 'Event' },
  { href: '/rsvp',       num: '03', label: 'RSVP', cta: true },
  { href: '/volunteer',  num: '04', label: 'Volunteer' },
  { href: '/gallery',    num: '05', label: 'Gallery' },
  { href: '/classmates', num: '06', label: 'Classmates' },
  { href: '/contact',    num: '07', label: 'Contact' },
];

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath === href || currentPath.startsWith(href + '/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,300..900,0..100,0..1;1,9..144,300..900,0..100,0..1&family=DM+Sans:opsz,wght@9..40,300..700&family=DM+Mono:wght@300;400;500&family=Caveat:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Clio High School Class of 2006 Reunion" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{pageTitle}</title>
  </head>
  <body class="grain min-h-screen bg-cream-50 font-body text-brand-900 antialiased">

    <!-- MASTHEAD — running head of the publication -->
    <div class="masthead">
      <div class="masthead-inner">
        <span class="mh-block">
          <span class="mh-mark">THE MUSTANG ANNUAL</span>
          <span class="mh-sep">·</span>
          <span class="mh-meta">Vol. 06 · No. 1</span>
        </span>
        <span class="mh-block mh-tagline">
          <span class="mh-meta">Anniversary Edition</span>
          <span class="mh-sep">·</span>
          <span class="mh-meta">Nov · MMXXVI</span>
          <span class="mh-sep">·</span>
          <span class="mh-meta">Clio · Michigan</span>
        </span>
        <span class="mh-block mh-folio">
          <span class="mh-meta">PG.</span>
          <span class="mh-num">{folio}</span>
        </span>
      </div>
    </div>

    <!-- NAV — editorial -->
    <header class="site-header">
      <nav class="site-nav">
        <a href="/" class="brand-link" aria-label="Home">
          <Logo size="md" />
        </a>

        <ul class="nav-links" role="list">
          {navLinks.map((l) => (
            <li>
              {l.cta ? (
                <a href={l.href} class:list={['nav-cta', isActive(l.href) && 'is-active']}>
                  <span class="nav-cta-num">{l.num}</span>
                  <span class="nav-cta-label">{l.label}</span>
                </a>
              ) : (
                <a href={l.href} class:list={['nav-link', isActive(l.href) && 'is-active']}>
                  <span class="nav-link-num">{l.num}</span>
                  <span class="nav-link-label">{l.label}</span>
                </a>
              )}
            </li>
          ))}
        </ul>

        <MobileMenu client:load />
      </nav>
    </header>

    <!-- MAIN -->
    <main class="site-main">
      <slot />
    </main>

    <!-- COLOPHON FOOTER -->
    <footer class="colophon">
      <div class="colophon-rule">
        <span class="colophon-mark">⌗</span>
        <span class="colophon-line"></span>
        <span class="colophon-mark">⌗</span>
      </div>

      <div class="colophon-grid">
        <div class="colophon-col">
          <h3 class="colophon-h">The Annual</h3>
          <p class="colophon-p">
            Published in advance of the Clio High School Class of 2006 twenty-year
            reunion. Set in <em>Fraunces</em> and <em>DM Sans</em>. Printed by
            Cloudflare Workers, anno MMXXVI.
          </p>
        </div>

        <div class="colophon-col">
          <h3 class="colophon-h">Departments</h3>
          <ul class="colophon-links">
            {navLinks.map((l) => (
              <li>
                <a href={l.href}>
                  <span class="colophon-num">{l.num}</span>
                  <span class="colophon-label">{l.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="colophon-col">
          <h3 class="colophon-h">External Files</h3>
          <ul class="colophon-links">
            <li>
              <a href="https://www.facebook.com/share/g/1G2ZxKc1GP/?mibextid=wwXIfr" target="_blank" rel="noopener noreferrer">
                <span class="colophon-num">↗</span>
                <span class="colophon-label">Class Facebook Group</span>
              </a>
            </li>
            <li>
              <a href="https://cliohighschool.net/class-of-2006.html" target="_blank" rel="noopener noreferrer">
                <span class="colophon-num">↗</span>
                <span class="colophon-label">cliohighschool.net</span>
              </a>
            </li>
            <li>
              <a href="https://www.youtube.com/playlist?list=PL72SyLQ6Qbwsx5XO_KjzEzyVGjmOF0HRN" target="_blank" rel="noopener noreferrer">
                <span class="colophon-num">↗</span>
                <span class="colophon-label">YouTube Archive</span>
              </a>
            </li>
          </ul>
        </div>

        <div class="colophon-col">
          <h3 class="colophon-h">Imprint</h3>
          <p class="colophon-p colophon-imprint">
            &copy; {new Date().getFullYear()} CLIO HIGH SCHOOL CLASS OF 2006 REUNION.
          </p>
          <p class="colophon-p colophon-llc">
            Designed &amp; built by<br />
            <span class="colophon-llc-name">Fisher Computer Solutions L.L.C.</span>
          </p>
        </div>
      </div>

      <div class="colophon-foot">
        <span>EST. 2006</span>
        <span class="colophon-foot-sep">·</span>
        <span>Once a Mustang. Always a Mustang.</span>
        <span class="colophon-foot-sep">·</span>
        <span>MMXXVI</span>
      </div>
    </footer>

    <style is:global>
      @import "../styles/global.css";

      /* =================================================================
         THE MUSTANG ANNUAL — shared chrome styles
         ================================================================= */

      /* --- Masthead --- */
      .masthead {
        background: var(--color-brand-900);
        color: var(--color-cream-50);
        border-bottom: 1px solid rgba(253, 251, 246, 0.12);
        position: relative;
        z-index: 5;
      }
      .masthead-inner {
        max-width: 88rem;
        margin: 0 auto;
        padding: 0.55rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        color: rgba(253, 251, 246, 0.72);
        flex-wrap: wrap;
      }
      .mh-block { display: inline-flex; align-items: baseline; gap: 0.5rem; }
      .mh-mark {
        color: var(--color-brand-400);
        font-weight: 600;
        letter-spacing: 0.28em;
      }
      .mh-tagline { margin-left: auto; }
      .mh-sep { opacity: 0.35; }
      .mh-meta { color: rgba(253, 251, 246, 0.72); }
      .mh-folio {
        margin-left: 1.5rem;
        padding-left: 1.5rem;
        border-left: 1px solid rgba(253, 251, 246, 0.15);
      }
      .mh-folio .mh-num {
        font-family: var(--font-display);
        font-style: italic;
        font-variation-settings: "opsz" 96, "wght" 600, "WONK" 1;
        font-size: 1.05rem;
        color: var(--color-cream-50);
        letter-spacing: -0.02em;
        text-transform: none;
      }
      @media (max-width: 720px) {
        .masthead-inner { font-size: 0.58rem; gap: 0.5rem; padding: 0.45rem 1rem; }
        .mh-tagline { display: none; }
      }

      /* --- Site header / nav --- */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(251, 246, 234, 0.94);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--color-brand-900);
      }
      .site-nav {
        max-width: 88rem;
        margin: 0 auto;
        padding: 0.65rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
      }
      .brand-link {
        display: inline-flex;
        text-decoration: none;
        flex-shrink: 0;
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: 0.2rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }
      @media (max-width: 980px) {
        .nav-links { display: none; }
      }
      .nav-link {
        display: inline-flex;
        align-items: baseline;
        gap: 0.35rem;
        padding: 0.5rem 0.85rem;
        text-decoration: none;
        font-family: var(--font-body);
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--color-brand-900);
        position: relative;
        transition: color 0.15s ease;
      }
      .nav-link-num {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--color-cream-700);
        transition: color 0.15s ease;
      }
      .nav-link-label {
        position: relative;
      }
      .nav-link-label::after {
        content: "";
        position: absolute;
        left: 0; right: 0; bottom: -3px;
        height: 2px;
        background: var(--color-brand-500);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.2s ease;
      }
      .nav-link:hover .nav-link-num { color: var(--color-brand-600); }
      .nav-link:hover .nav-link-label::after,
      .nav-link.is-active .nav-link-label::after {
        transform: scaleX(1);
      }
      .nav-link.is-active .nav-link-num { color: var(--color-brand-600); }
      .nav-link.is-active .nav-link-label { color: var(--color-brand-700); }

      .nav-cta {
        display: inline-flex;
        align-items: baseline;
        gap: 0.4rem;
        padding: 0.5rem 0.95rem;
        margin-left: 0.4rem;
        background: var(--color-brand-500);
        color: var(--color-cream-50);
        text-decoration: none;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        box-shadow: 3px 3px 0 var(--color-brand-900);
        transition: transform 0.15s ease, box-shadow 0.15s ease;
      }
      .nav-cta:hover {
        transform: translate(-2px, -2px);
        box-shadow: 5px 5px 0 var(--color-brand-900);
      }
      .nav-cta-num {
        font-size: 0.6rem;
        opacity: 0.7;
      }
      .nav-cta.is-active { background: var(--color-brand-900); }

      /* --- Main wrap --- */
      .site-main {
        max-width: 88rem;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
        position: relative;
        z-index: 2;
      }
      @media (max-width: 720px) {
        .site-main { padding: 1.25rem 1rem 3rem; }
      }

      /* Page-opener strip — folio + section label, used at the top of every page */
      .page-opener {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1rem;
        padding: 0 0 1rem;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid var(--color-brand-900);
        position: relative;
      }
      .page-opener::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: -5px;
        right: 0;
        height: 1px;
        background: var(--color-brand-900);
        opacity: 0.35;
      }
      .page-opener-section {
        display: inline-flex;
        flex-direction: column;
        gap: 0.3rem;
      }
      .page-opener-kicker {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.28em;
        color: var(--color-cream-700);
      }
      .page-opener-label {
        font-family: var(--font-display);
        font-variation-settings: "opsz" 96, "wght" 600, "WONK" 1;
        font-style: italic;
        font-size: clamp(1.6rem, 3.6vw, 2.5rem);
        line-height: 1;
        color: var(--color-brand-900);
        letter-spacing: -0.02em;
      }
      .page-opener-meta {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.24em;
        color: var(--color-cream-700);
        text-align: right;
      }

      /* --- Colophon footer --- */
      .colophon {
        background: var(--color-brand-900);
        color: var(--color-cream-100);
        padding: 3rem 1.5rem 1.5rem;
        margin-top: 3rem;
        position: relative;
        z-index: 2;
      }
      .colophon-rule {
        max-width: 88rem;
        margin: 0 auto 2rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }
      .colophon-mark { color: var(--color-brand-400); font-size: 0.9rem; }
      .colophon-line {
        flex: 1;
        height: 1px;
        background: rgba(253, 251, 246, 0.18);
      }
      .colophon-grid {
        max-width: 88rem;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 2.5rem;
      }
      @media (max-width: 900px) {
        .colophon-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      }
      @media (max-width: 540px) {
        .colophon-grid { grid-template-columns: 1fr; }
      }
      .colophon-h {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.26em;
        color: var(--color-brand-400);
        margin: 0 0 1rem;
        font-weight: 600;
      }
      .colophon-p {
        font-family: var(--font-body);
        font-size: 0.85rem;
        color: rgba(253, 251, 246, 0.7);
        line-height: 1.55;
        margin: 0 0 0.65rem;
      }
      .colophon-p em {
        font-family: var(--font-display);
        font-style: italic;
        color: var(--color-cream-100);
        font-variation-settings: "opsz" 14, "wght" 500;
      }
      .colophon-links { list-style: none; margin: 0; padding: 0; }
      .colophon-links li { margin-bottom: 0.35rem; }
      .colophon-links a {
        display: inline-flex;
        align-items: baseline;
        gap: 0.6rem;
        text-decoration: none;
        color: rgba(253, 251, 246, 0.78);
        transition: color 0.15s ease;
      }
      .colophon-links a:hover { color: var(--color-brand-400); }
      .colophon-num {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: rgba(253, 251, 246, 0.45);
        width: 1.2rem;
        flex-shrink: 0;
      }
      .colophon-label {
        font-family: var(--font-body);
        font-size: 0.92rem;
      }
      .colophon-imprint {
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 0.65rem;
        color: rgba(253, 251, 246, 0.55);
      }
      .colophon-llc {
        font-family: var(--font-body);
        line-height: 1.4;
        font-size: 0.88rem;
        color: rgba(253, 251, 246, 0.7);
      }
      .colophon-llc-name {
        font-family: var(--font-display);
        font-style: italic;
        font-variation-settings: "opsz" 24, "wght" 600;
        font-size: 1.05rem;
        color: var(--color-brand-400);
        letter-spacing: -0.01em;
      }
      .colophon-foot {
        max-width: 88rem;
        margin: 2.5rem auto 0;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(253, 251, 246, 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        flex-wrap: wrap;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.28em;
        color: rgba(253, 251, 246, 0.5);
      }
      .colophon-foot-sep { color: var(--color-brand-500); }
    </style>
  </body>
</html>
