---
interface Props {
  title: string;
  adminEmail: string;
}

const { title, adminEmail } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/admin';

const navItems = [
  { label: 'Dashboard',    href: '/admin/' },
  { label: 'Classmates',   href: '/admin/classmates' },
  { label: 'Submissions',  href: '/admin/submissions' },
  { label: 'Email blast',  href: '/admin/blast' },
  { label: 'Planning',     href: '/admin/planning' },
  { label: 'Ledger',       href: '/admin/ledger' },
  { label: 'Photos',       href: '/admin/photos' },
  { label: 'Settings',     href: '/admin/settings' },
  { label: 'Admins',       href: '/admin/admins' },
];

const isActive = (href: string) => {
  const target = href.replace(/\/$/, '');
  return currentPath === target;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Outfit:wght@300..700&family=Oswald:wght@500;600;700&family=Dancing+Script:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} · Admin · Clio HS Class of 2006</title>
  </head>
  <body class="grain min-h-screen bg-cream-50 font-body text-brand-900 antialiased">
    <a href="#main" class="skip-link">Skip to content</a>

    <header
      class="sticky top-0 border-b border-cream-300/40 bg-cream-50/95 backdrop-blur-md"
      style="z-index: 100; -webkit-backdrop-filter: blur(12px);"
    >
      <div class="mx-auto flex max-w-7xl flex-col gap-2 px-4 py-3 sm:px-6">
        {/* Top row: brand + user */}
        <div class="flex items-center justify-between gap-4">
          <div class="flex items-baseline gap-3">
            <a href="/" class="font-heading text-sm font-semibold uppercase tracking-[0.18em] text-brand-900 hover:text-brand-600 transition-colors">
              Clio High School
            </a>
            <span class="hidden sm:inline text-cream-400/70" aria-hidden="true">·</span>
            <span class="hidden sm:inline font-display italic text-sm text-accent-600">Class of '06</span>
            <span class="text-cream-400/70" aria-hidden="true">·</span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-900 px-2.5 py-0.5">
              <span class="h-1.5 w-1.5 rounded-full bg-accent-400" aria-hidden="true"></span>
              <span class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.2em] text-cream-100">Admin</span>
            </span>
          </div>

          <div class="flex items-center gap-3 text-xs">
            <span class="hidden sm:inline text-cream-700">
              <span class="font-mono text-[0.7rem]">{adminEmail}</span>
            </span>
            <a
              href="/admin/logout"
              class="rounded-full border border-cream-400 bg-white px-3 py-1 font-mono text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-brand-700 transition-all hover:border-brand-500 hover:bg-brand-50 hover:text-brand-900"
            >
              Sign out
            </a>
          </div>
        </div>

        {/* Bottom row: section tabs */}
        <nav class="flex items-center gap-1 -mb-1" aria-label="Admin sections">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                'relative inline-flex items-center gap-2 px-3 py-2 text-sm font-medium transition-colors duration-150',
                'after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:origin-center after:scale-x-0 after:bg-brand-500 after:transition-transform after:duration-200',
                'hover:text-brand-900 hover:after:scale-x-100',
                isActive(item.href) ? 'text-brand-900 after:scale-x-100' : 'text-brand-700',
              ]}
            >
              {item.label}
            </a>
          ))}
          <span class="ml-auto hidden sm:inline-flex items-center gap-1.5 text-xs">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse" aria-hidden="true"></span>
            <span class="font-mono text-[0.62rem] font-semibold uppercase tracking-[0.2em] text-cream-700">Live</span>
          </span>
        </nav>
      </div>
    </header>

    <main id="main" class="relative mx-auto max-w-7xl px-4 py-10 sm:px-6 sm:py-12" style="z-index: 2;">
      <slot />
    </main>

    <footer class="mt-12 border-t border-cream-300/60 bg-brand-900 text-cream-300">
      <div class="mx-auto flex max-w-7xl flex-col items-center gap-2 px-4 py-6 sm:flex-row sm:justify-between sm:px-6">
        <p class="font-mono text-[0.62rem] uppercase tracking-[0.22em] text-cream-400">
          Internal · Clio HS '06 Reunion · Restricted access
        </p>
        <p class="font-mono text-[0.62rem] uppercase tracking-[0.22em] text-cream-400">
          Signed in as <span class="text-cream-100">{adminEmail}</span>
        </p>
        <p class="font-mono text-[0.62rem] uppercase tracking-[0.22em] text-cream-400">
          Built by
          <a
            href="https://fishercomputersolutions.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-cream-100 underline-offset-2 transition-colors duration-150 hover:text-accent-300 hover:underline"
          >Fisher Computer Solutions</a>
        </p>
      </div>
    </footer>

    <style is:global>
      @import "../styles/global.css";

      .skip-link {
        position: absolute;
        left: 1rem;
        top: -3rem;
        z-index: 200;
        padding: 0.5rem 0.85rem;
        background: var(--color-brand-900);
        color: var(--color-cream-50);
        border-radius: 0.5rem;
        font-family: var(--font-heading);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-weight: 600;
        text-decoration: none;
        transition: top 0.2s ease;
      }
      .skip-link:focus { top: 0.75rem; }

      /* Stat tile — modern soft card with optional accent variant */
      .admin-tile {
        position: relative;
        overflow: hidden;
        border-radius: 1rem;
        border: 1px solid var(--color-cream-300);
        background: rgba(255, 255, 255, 0.85);
        padding: 1.25rem;
        transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
        box-shadow:
          0 1px 0 rgba(13, 11, 10, 0.02),
          0 1px 3px rgba(13, 11, 10, 0.04),
          0 8px 16px -8px rgba(13, 11, 10, 0.06);
      }
      .admin-tile-label {
        font-family: var(--font-heading);
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--color-cream-700);
      }
      .admin-tile-value {
        margin-top: 0.4rem;
        font-family: var(--font-heading);
        font-size: 2.5rem;
        font-weight: 700;
        line-height: 1;
        color: var(--color-brand-900);
        font-variant-numeric: tabular-nums;
        letter-spacing: -0.01em;
      }
      .admin-tile-sub {
        margin-top: 0.35rem;
        font-size: 0.78rem;
        color: var(--color-cream-700);
      }
      .admin-tile.is-brand {
        background: linear-gradient(180deg, var(--color-brand-50) 0%, rgba(255, 255, 255, 0.85) 80%);
        border-color: var(--color-brand-200);
      }
      .admin-tile.is-brand .admin-tile-value { color: var(--color-brand-700); }
      .admin-tile.is-emerald {
        background: linear-gradient(180deg, #ecfccb 0%, rgba(255, 255, 255, 0.85) 80%);
        border-color: #bef264;
      }
      .admin-tile.is-emerald .admin-tile-value { color: #4d7c0f; }
      .admin-tile.is-rose {
        background: linear-gradient(180deg, #ffe4e6 0%, rgba(255, 255, 255, 0.85) 80%);
        border-color: #fda4af;
      }
      .admin-tile.is-rose .admin-tile-value { color: #be123c; }

      /* Data tables */
      .admin-table-wrap {
        overflow-x: auto;
        border-radius: 1rem;
        border: 1px solid var(--color-cream-300);
        background: rgba(255, 255, 255, 0.95);
        box-shadow:
          0 1px 0 rgba(13, 11, 10, 0.02),
          0 1px 3px rgba(13, 11, 10, 0.04),
          0 8px 16px -8px rgba(13, 11, 10, 0.06);
      }
      .admin-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
        color: var(--color-brand-900);
      }
      .admin-table thead th {
        position: sticky;
        top: 0;
        background: var(--color-cream-100);
        padding: 0.7rem 1rem;
        text-align: left;
        font-family: var(--font-heading);
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--color-brand-700);
        border-bottom: 1px solid var(--color-cream-300);
        white-space: nowrap;
      }
      /* Sortable headers — wired up by the global sort helper below.
         The helper toggles .sort-asc / .sort-desc; CSS handles affordance. */
      .admin-table thead th.sortable {
        cursor: pointer;
        user-select: none;
      }
      .admin-table thead th.sortable:hover {
        color: var(--color-brand-900);
        background: var(--color-cream-200);
      }
      .admin-table thead th.sortable .sort-indicator {
        display: inline-block;
        margin-left: 0.35em;
        color: var(--color-cream-500);
        font-size: 0.85em;
        font-weight: 700;
        transition: color 0.12s ease;
      }
      .admin-table thead th.sort-asc  .sort-indicator,
      .admin-table thead th.sort-desc .sort-indicator {
        color: var(--color-brand-700);
      }
      .admin-table tbody td {
        padding: 0.75rem 1rem;
        vertical-align: top;
        border-bottom: 1px solid var(--color-cream-200);
        color: var(--color-brand-800);
        line-height: 1.4;
      }
      .admin-table tbody tr:last-child td { border-bottom: 0; }
      .admin-table tbody tr {
        transition: background 0.12s ease;
      }
      .admin-table tbody tr:hover {
        background: rgba(242, 105, 1, 0.04);
      }
      .admin-table td.mono,
      .admin-table th.mono,
      .admin-table td.num,
      .admin-table th.num {
        font-family: var(--font-mono, ui-monospace, SFMono-Regular, monospace);
        font-variant-numeric: tabular-nums;
      }
      .admin-table td.num,
      .admin-table th.num { text-align: right; }
      .admin-table td.dim { color: var(--color-cream-700); }
      .admin-table .empty-row td {
        text-align: center;
        padding: 2.5rem 1rem;
        color: var(--color-cream-700);
        font-style: italic;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.2rem 0.6rem;
        border-radius: 9999px;
        font-family: var(--font-heading);
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        border: 1px solid currentColor;
      }
      .pill.yes    { color: #166534; background: #dcfce7; border-color: #86efac; }
      .pill.maybe  { color: #92400e; background: #fef3c7; border-color: #fcd34d; }
      .pill.no     { color: var(--color-cream-700); background: var(--color-cream-100); border-color: var(--color-cream-300); }
      .pill.in     { color: #166534; background: #dcfce7; border-color: #86efac; }
      .pill.out    { color: #9f1239; background: #ffe4e6; border-color: #fda4af; }
      .pill.self   { color: var(--color-brand-700); background: var(--color-brand-50); border-color: var(--color-brand-200); }

      .check-mark { color: #16a34a; font-weight: 700; }
      .dash-mark  { color: var(--color-cream-500); }
    </style>

    <script is:inline>
      // Convert every <time datetime="…"> on the page from UTC ISO into the
      // viewer's local 12-hour time. Server-rendered fallback text remains
      // until this runs (a few ms after parse).
      (function () {
        const now = new Date();
        const sameYear = now.getFullYear();
        document.querySelectorAll('time[datetime]').forEach(function (el) {
          const iso = el.getAttribute('datetime');
          if (!iso) return;
          const d = new Date(iso);
          if (isNaN(d.getTime())) return;
          const opts = {
            month: 'short',
            day: 'numeric',
            year: d.getFullYear() === sameYear ? undefined : 'numeric',
            hour: 'numeric',
            minute: '2-digit',
            hour12: true,
          };
          el.textContent = d.toLocaleString('en-US', opts);
          if (!el.getAttribute('title')) {
            el.setAttribute('title', d.toLocaleString('en-US', {
              dateStyle: 'full', timeStyle: 'long',
            }));
          }
        });
      })();

      // Universal click-to-sort for any <table class="admin-table">.
      // Opt out of the entire table with .admin-table--no-sort, or skip a
      // single column by adding .no-sort (or data-no-sort) to its <th>.
      // Detection: numeric cells get numeric compare, <time datetime>
      // cells get ISO compare, everything else case-insensitive string.
      (function () {
        function cellSortValue(cell) {
          if (!cell) return '';
          const timeEl = cell.querySelector('time[datetime]');
          if (timeEl) return { iso: timeEl.getAttribute('datetime') || '' };
          // Strip whitespace and the en-dash placeholder we use for empty.
          const raw = (cell.textContent || '').trim();
          if (raw === '' || raw === '—' || raw === '–') return '';
          return raw;
        }

        function detectKind(values) {
          // Need at least one non-empty cell to decide.
          let sawValue = false;
          let allTime = true;
          let allNumeric = true;
          const numRe = /^-?\$?[\d,]+(\.\d+)?%?$/;
          for (const v of values) {
            if (v === '' || v == null) continue;
            sawValue = true;
            if (typeof v === 'object' && v.iso) {
              allNumeric = false;
            } else {
              allTime = false;
              if (!numRe.test(String(v).trim())) allNumeric = false;
            }
          }
          if (!sawValue) return 'string';
          if (allTime) return 'time';
          if (allNumeric) return 'numeric';
          return 'string';
        }

        function compareFor(kind) {
          if (kind === 'time') {
            return (a, b) => {
              const ai = a && typeof a === 'object' ? Date.parse(a.iso) : NaN;
              const bi = b && typeof b === 'object' ? Date.parse(b.iso) : NaN;
              if (isNaN(ai) && isNaN(bi)) return 0;
              if (isNaN(ai)) return 1;
              if (isNaN(bi)) return -1;
              return ai - bi;
            };
          }
          if (kind === 'numeric') {
            const toNum = (v) => {
              if (v === '' || v == null) return NaN;
              return parseFloat(String(v).replace(/[$,%]/g, ''));
            };
            return (a, b) => {
              const an = toNum(a), bn = toNum(b);
              if (isNaN(an) && isNaN(bn)) return 0;
              if (isNaN(an)) return 1;
              if (isNaN(bn)) return -1;
              return an - bn;
            };
          }
          // String fallback — empties always sort to the bottom regardless of dir.
          const collator = new Intl.Collator('en', { sensitivity: 'base', numeric: true });
          return (a, b) => {
            const ae = a === '' || a == null;
            const be = b === '' || b == null;
            if (ae && be) return 0;
            if (ae) return 1;
            if (be) return -1;
            return collator.compare(String(a), String(b));
          };
        }

        function sortTable(table, colIndex, direction) {
          const tbody = table.tBodies[0];
          if (!tbody) return;
          const rows = Array.from(tbody.rows).filter((r) => !r.classList.contains('empty-row'));
          if (rows.length < 2) return;

          const values = rows.map((row) => cellSortValue(row.cells[colIndex]));
          const kind = detectKind(values);
          const cmp = compareFor(kind);
          const indexed = rows.map((row, i) => ({ row, val: values[i] }));
          indexed.sort((a, b) => {
            const c = cmp(a.val, b.val);
            return direction === 'desc' ? -c : c;
          });
          // Re-append in new order; "empties always last" for string/numeric is
          // baked into compareFor, but for desc we want empties to still trail
          // — re-pin them after the sort.
          const empties = indexed.filter((x) => x.val === '' || x.val == null);
          const filled  = indexed.filter((x) => !(x.val === '' || x.val == null));
          for (const x of filled)  tbody.appendChild(x.row);
          for (const x of empties) tbody.appendChild(x.row);
        }

        function setIndicator(th, state) {
          th.classList.remove('sort-asc', 'sort-desc');
          let ind = th.querySelector('.sort-indicator');
          if (!ind) {
            ind = document.createElement('span');
            ind.className = 'sort-indicator';
            th.appendChild(ind);
          }
          if (state === 'asc')       { th.classList.add('sort-asc');  ind.textContent = '▲'; }
          else if (state === 'desc') { th.classList.add('sort-desc'); ind.textContent = '▼'; }
          else                       { ind.textContent = '↕'; }
        }

        function wireTable(table) {
          if (table.classList.contains('admin-table--no-sort')) return;
          if (table.dataset.sortWired === '1') return;
          table.dataset.sortWired = '1';
          const headRow = table.tHead && table.tHead.rows[0];
          if (!headRow) return;
          const ths = Array.from(headRow.cells);
          ths.forEach((th, i) => {
            if (th.classList.contains('no-sort') || th.dataset.noSort != null) return;
            // Skip headers spanning multiple columns — sort can't disambiguate.
            if (th.colSpan && th.colSpan > 1) return;
            th.classList.add('sortable');
            setIndicator(th, 'none');
            th.addEventListener('click', () => {
              const cur = th.classList.contains('sort-asc')  ? 'asc'
                        : th.classList.contains('sort-desc') ? 'desc'
                        : null;
              const next = cur === 'asc' ? 'desc' : 'asc';
              ths.forEach((other) => { if (other !== th) setIndicator(other, 'none'); });
              setIndicator(th, next);
              sortTable(table, i, next);
            });
          });
        }

        document.querySelectorAll('table.admin-table').forEach(wireTable);
      })();
    </script>
  </body>
</html>
