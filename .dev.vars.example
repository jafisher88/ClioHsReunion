# Cloudflare Workers secrets for local development
# Copy this file to .dev.vars and fill in your values
# NEVER commit .dev.vars — it contains credentials

# Google OAuth for /admin sign-in. Create credentials at
# https://console.cloud.google.com/apis/credentials (Web application).
# Authorized redirect URI: https://cliohsreunion.com/admin/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Used to HMAC-sign the admin session cookie. Generate with:
#   openssl rand -base64 48
SESSION_SECRET=

# Optional: Resend API key for emailing RSVP confirmations to the organizer.
# Leave blank to skip email and only persist RSVPs to D1.
RESEND_API_KEY=

# Resend webhook signing secret. Set this so /api/webhooks/resend can verify
# inbound events (delivered / opened / clicked / bounced / complained / etc.)
# and update the per-recipient status on each blast in real time.
#
# How to get one:
#   1. Resend dashboard → Webhooks → Add Endpoint
#   2. URL: https://cliohsreunion.com/api/webhooks/resend
#   3. Subscribe to all "email.*" events
#   4. Copy the "Signing Secret" (starts with `whsec_`) and paste below.
#
# In production:  npx wrangler secret put RESEND_WEBHOOK_SECRET
RESEND_WEBHOOK_SECRET=

# Where confirmation/notification emails should be sent (the organizer).
ORGANIZER_EMAIL=
